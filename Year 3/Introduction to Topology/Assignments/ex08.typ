#question()
#subquestion()
יהי $(X, tau)$ מרחב האוסדרוף קומפקטי מקומית. נראה שאם $Y subset.eq X$ תת־קבוצה פתוחה או סגורה אזי $Y$ עם הטופולוגיה המושרית הוא מרחב האוסדרוף קומפקטי מקומית.

#proof[
  $X$ קומפקטי מקומית ולכן לכל $x in X$ יש סביבה $C subset.eq X$ קומפקטית וקבוצה פתוחה $W in tau$ כך ש־$x in W subset.eq C$.\
  שנית, ראינו שמרחב האוסדרוף הוא קומפקטי מקומית אם ורק אם לכל נקודה בו יש סביבה פתוחה בעלת סגור קומפקטי ונרצה להשתמש בטענה הזאת שכן אם $Y subset.eq X$ מהיות $X$ הואסדרוף גם $Y$ האוסדרוף.\
  נניח ש־$Y$ פתוחה, יהי $y in Y$ ומכך ש־$X$ מרחב קומפקטי מקומית קיימת סביבה פתוחה $V subset.eq X$ כך ש־$closure(V)$ היא קבוצה קומפקטית ב־$X$.\
  בתרגיל הקודם ראינו שמרחב האוסדרוף קומפקטי הוא מרחב רגולרי (ואף נורמלי) ונטען שהתכונה הזאת נכונה גם עבור מרחב קומפקטי מקומית:\
  שכן אם $x in X$ ו־$x in U subset.eq X$ סביבה פתוחה של $x$, נסמן $F=X without U = U^c$ ו־$F$ קבוצה סגורה כך ש־$x in.not F$.\
  מהיות $X$ קומפקטי מקומית קיימת $V$ סביבה פתוחה של $x$ כך ש־$K=closure(V)$ קומפקטי.\
  החיתוך $F inter K$ הוא גם קומפקטי כתת־קבוצה סגורה בקבוצה קומפקטי ומכיוון ש־$X$ האוסדרוף ו־$x in.not F inter K$ נובע שקיימות שתי קבוצות פתוחות וזרות $W_1, W_2 subset.eq X$ כך ש־$x in W_1$ וגם $(F inter K) subset.eq W_2$.\
  נבחר את הסביבה $W$ להיות $W=W_1 inter V$ כפתוחה של חיתוך של פתוחות ו־$x in W_1 inter V$.\
  נניח בשלילה שקיים $y in closure(W)$ כך ש־$y in F$ ולכן מצד אחד נקבל ש־$closure(W) subset.eq closure(V) = K$ ולכן $y in K$ ולכן $y in F inter K$ אבל זה בידיוק אומר ש־$y in W_2$ אבל $W subset.eq W_1$ ולכן $closure(W) subset.eq closure(W_1)$ אבל $W_1, W_2$ פתוחות וזרות ולכן $closure(W_1) inter closure(W_2) = emptyset$ ולכן $y in closure(W) subset.eq closure(W_1)$ ולכן $y in.not W_2$ בסתירה.\
  לכן אין אף נקודה בסגורה של $W$ שנמצאת ב־$F$ ולכן $closure(W) subset.eq U$ וקיבלנו שהמרחב רגולרי.\
  אם כך, אם נסתכל על $y in Y inter V$ מהרגולריות נקבל שקיימת סביבה פתוחה $W subset.eq X$ כך שמתקיים $y in W subset.eq closure(W) subset.eq Y inter V$ ולכן $closure(W) subset.eq Y$ והיא קומפקטית כי \
  $closure(W) subset.eq V subset.eq closure(V)$ ו־$closure(W)$ היא תת־קבוצה סגורה בתוך קבוצה קומפקטית ולכן קומפקטית. יתר על־כן, מאחרת ש־$closure(W) subset.eq Y$ נובע שהיא קומפקטית גם בטופולוגיית התת־מרחב של $Y$ (קומפקטיות לא תלויה במרחב המכיל) ומהגדרה קיבלנו ש־$Y$ קומפקטי מקומית.\
  במקרה השני נניח ש־$Y$ היא קבוצה סגורה ונסתכל כמקודם על החיתוך $Y inter V$ ונסתכל על הסגור שלו ב־$Y$ בתוך $Y$, נסמנו $closure(Y) (Y inter V)$ ומתקיים
  $ closure(Y) (Y inter V) = Y inter closure(X)(Y inter V) $
  מהיות $Y inter V subset.eq V$ הרי שסגור שלו ב־$X$ מוכל בסגור של $V$ כלומר $closure(X) (Y inter V) subset.eq closure(X)(V)$ כלומר $closure(Y)(Y inter V) subset.eq Y inter K subset.eq K$.\
  אבל $Y inter K$ היא קבוצה קומפקטית ב־$X$ כי $K$ קומפקטית ו־$Y$ סגורה ולכן זה חיתוך של סגורה וקומפקטית ו־$closure(Y)(Y inter V) subset.eq Y inter K$ גם קומפקטית כתת־קבוצה סגורה בקבוצה קומפקטית כלומר ראינו שלכל $y in Y$ הקבוצה $Y inter V$ היא סביבה פתוחה ב־$Y$ והסגור שלה הוא קומפקטי וזו בידיוק ההגדרה של קומפקטי מקומית.
]

#subquestion()
יהיו $X_1, dots.h, X_n$ מרחבים קומפקטיים מקומית ונוכיח כי $X = product_(i=1)^n X_i$ עם טופולוגיית המכפלה הוא מרחב קומפקטי מקומית.

#proof[
  יהי $x=(x_1, x_2, dots.h, x_n) in X$ ולכל $1<=i<=n$ מתקיים ש־$x_i in X_i$ וכל $X_i$ הוא מרחב קומפקטי מקומית ולכן ל־$x_i$ קיימת סביבה פתוחה $U_i subset.eq X_i$ כך ש־$K = closure(X_i)(U_i)$ הוא קבוצה קומפקטית ב־$X_i$, נגדיר $U = product_(i=1)^n U_i$. ברור כי $x in U$ ו־$U$ היא פתוחה כמכפלה סופית של קבוצות פתוחות (ומהגדרת טופולוגיית המכפלה). עוד מתקיים מהגדרת טופולוגיית המכפלה
  $ closure(X)(U) = closure(X)(product_(i=1)^n U_i) = product_(i=1)^n closure(X_i)(U_i) = product_(i=1)^n K_i = K $
  אבל $K$ קומפקטית כמכפלה סופית של קבוצות קומפקטיות ממשפט טיכונוף כלומר קיבלנו קומפקטיות מקומית, כנדרש.
]

#subquestion()
יהי ${X_i}_(i in I)$ אוסף מרחבים טופולוגיים. נוכיח כי $X=product_(i in I) X_i$ עם טופולוגיית המכפלה הוא מרחב קומפקטי מקומית אם ורק אם לכל $i in I$ המרחב $X_i$ קומפקטי מקומית וקיימת $J subset.eq I$ כך ש־$I without J$ סופית כך שלכל $i in J$ המרחב $X_i$ קומפקטי.

#proof[\
  $<==$ נניח כי $X=product_(i in I) X_i$ קומפקטית מקומית.\
  נטען שאם יש לנו פונקציה $f:X arrow Y$ שהיא גם על, גם רציפה וגם פתוחה ו־$X$ קומפקטי מקומית אז גם $Y$ קומפקטי מקומית.\
  זה נכון כי נבחר $y in Y$ אז קיים $x in X$ כך ש־$f(x)=y$. $X$ קומפקטי מקומית ולכן קיימת סביבה פתוחה $U subset.eq X$ ו־$K subset.eq X$ קומפקטית כך שמתקיים $x in U subset.eq K$ ובפרט תחת הפעלת $f$
  $ f(x) in f(U) subset.eq f(K) ==> y in f(U) subset.eq f(K) $
  אבל $f$ העתקה פתוחה ולכן $f(U)$ פתוחה ב־$Y$ (כי $U$ פתוחה ב־$X$) ו־$f(K)$ קומפקטית כתמונה של פונקציה קומפקטית וזה בידיוק אומר ש־$Y$ קומפקטי מקומית.\
  לכל $i in I$, ההטלה $pi_i : X arrow X_i$ היא פונקציה על, רציפה ופתוחה ולכן מהטענה לעיל נובע שהתמונה שלה היא מרחב קומפקטי מקומית ולכן כל $X_i$ קומפקטי מקומית.\
  נראה כי כמעט כל המרחבים קומפקטיים: תהיי $x = (x_i)_(i in I) in X$ ומכך ש־$X$ קומפקטי מקומית קיימת ל־$x$ סביבה פתוחה $U$ כך ש־$K = closure(X)(U)$ היא קבוצה קומפקטית ב־$X$.\
  מהגדרת טופולוגיית המכפלה הסביבה הפתוחה $U$ היא מהצורה $U = product_(i in I) U_i$ כאשר קיימת תת־קבוצה סופית $I_0 subset.eq I$ כך שלכל $i in I without I_0$ מתקיים $U_i = X_i$. מתקיים
  $ K = closure(X)(U) = product_(i in I) closure(X_i)(U_i) $
  $K$ קומפקטי במרחב המכפלה ולכן ממשפט טיכונוף כל איבר במכפלה הוא קומפקטי, בפרט לכל $i in I without I_0$ מתקיים ש־$closure(X_i)(U_i)=closure(X_i)(X_i) = X_i$ הוא קומפקטי.\
  אז אם נבחר $J=I without I_0$ אז הקבוצה $I without J = I_0$ היא סופית ולכל $i in J$ מתקיים ש־$X_i$ קומפקטי מקומית, כנדרש.\
  $==>$ נניח שלכל $i in I$ המרחב $X_i$ קומפקטי מקומית וקיימת $J subset.eq I$ כך ש־$I_0 = I without J$ סופית ולכל $i in J$ המרחב $X_i$ קומפקטי.\
  תהיי $x in X$. לכל $i in I_0$ המרחב $X_i$ קומפקטי מקומית ולכן קיימת ל־$x_i$ (הקורדינאטה ה־$i$ של $x$) סביבה פתוחה $U_i subset.eq X_i$ כך ש־$K_i = closure(X_i)(U_i)$ קומפקטי ב־$X_i$ ולכל $in J$ המרחב $X_i$ גלובאלי ולכן $U_i = X_i$ זו הסביבה הפתוחה שלה ו־$closure(X_i)(X_i) = X_i$ קומפקטי.\
  נגדיר $U=product_(i in I) X_i$ וזו קבוצה פתוחה בטופולוגיית המכפלה מהגדרת טופולוגיית המכפלה ו־$x in U$, מתקיים
  $ closure(X)(U) = product_(i in I) closure(X_i)(U_i) = product_(i in I_0) K_i times product_(i in J) X_i = K $
  כל איבר במכפלה הוא קבוצה קומפקטית ולכן ממשפט טיכונוף המכפלה הזאת היא קומפקטית ולכן $closure(X)(U)$ קומפקטי, כלומר מצאנו לכל נקודה סביבה פתוחה בעלת סגור קומפקטי ולכן $X$ קומפקטי מקומית.
]


#question()
#subquestion()
יהי $X$ מרחב האוסדרוף. נראה ש־$X$ הוא קומפקטי מקומית אם ורק אם קיים מרחב האוסדרוף קומפקטי $Y$ כך ש־$X$ הומאומורפי לתת־קבוצה פתוחה של $Y$.

#proof[
  $==>$ נניח שקיים מרחב האוסדרוף קומפקטי $Y$ כך ש־$X$ הומיאמורפי לתת־קבוצה פתוחה של $Y$.\
  מרחב האוסדרוף קומפקטי $Y$ הוא בהכרח מרחב קומפקטי מקומית ומסעיף א' בשאלה הקודמת קיבלנו שתת־מרחב פתוח של מרחב האוסדרוף קומפקטי מקומית הוא קומפקטי מקומית בעצמו ביחס לטופולוגיה המושרית ומכיוון ש־$X$ הומאומורפי לתת־קבוצה פתוחה ב־$Y$ וקומפקטיות מקומית נשמרת תחת הומאומורפיזם (כי הומאומורפיזם היא פונקציה ששומרת על מבנה של קבוצות פתוחות) נקבל ש־$X$ הוא מרחב קומפקטי מקומית.\
  $<==$ נניח ש־$X$ מרחב האוסדרוף קומפקטי מקומית.\
  אם $X$ קומפקטי נבחר $Y=X$ וסיימנו. אחרת, נגדיר $Y = X union {infinity}$ כאשר $infinity$ היא נקודה חדשה שאינה ב־$X$ ונגדיר את הטופולוגיה $tau_Y$ על $Y$ להיות האוסף של כל הקבוצות $U$ הפתוחות ב־$X$ וכל הקבוצות מהצורה $Y without K$, כאשר $K subset.eq X$ היא קבוצה קומפקטית וסגורה ב־$X$.\
  מכיוון ש־$X=Y without emptyset$ ו־$emptyset$ קומפקטית ברור כי $X$ היא תת־קבוצה פתוחה של $Y$ ושהטופולוגיה המושרית על $X$ מ־$Y$ היא הטופולוגיה המקורית של $X$, אז נשאר להראות ש־$Y$ הוא מרחב האוסדרוף וקומפקטי.\
  הוא אכן קומפקטי כי אם $cal(O)$ הוא כיסוי פתוח של $Y$ אז יש לפחות קבוצה אחת $V_0$ כך ש־$infinity in V_0$ ולכן $V_0 = Y without K_0$ עבור $K_0$ קומפקטית ב־$X$. $K_0$ קומפקטית ב־$X$ ושאר קבוצות הכיסוי חותכות את $X$ ומייצרות כיסוי פתוח ל־$K_0$ ב־$X$ אבל $K_0$ קומפקטית ולכן קיים לה תת־כיסוי סופי $U_1, dots.h, U_m$ ולכן $V_0, U_1, dots.h, U_m$ מכסה את $V_0$ ואת $K_0$ אבל $Y= V_0 union K_0$ ולכן $Y$ קומפקטי.\
  בשביל להראות ש־$Y$ האוסדרוף, יהיו $x_1, x_2 in Y$. אם $x_1, x_2 in X$ אז $X$ הואסדרוף ולכן קיימות סביבות פתוחות וזרות ב־$X$ והן פתוחות וזרות גם ב־$Y$.\
  בלי הגבת הכלליות $x_1 = x, x_2 = infinity$ ומכך ש־$X$ קומפקטי מקומיות קיימת ל־$x$ סביבה פתוחה $U subset.eq X$ כך ש־$K=closure(X)(U)$ קומפקטי ומהיות $X$ האוסדרוף, $K$ סגור גם ב־$X$ ולכן $U$ היא סביבה פתוחה של $x$ ב־$Y$ ו־$V=Y without K$ היא סביבה פתוחה של $infinity$ ב־$Y$ והן זרות כי
  $ U inter (Y without K) subset.eq K inter (Y without K) = emptyset $
  ולכן $Y$ הואסדרוף.
]

#subquestion()
נראה שאם $X$ מרחב האוסדרוף קומפקטי מקומית אז $X$ מרחב מקטגוריה שנייה.

#proof[
  יהי $X$ מרחב האוסדרוף קומפקטי מקומית ולפי הסעיף הקודם קיים מרחב האוסדרוף קומפקטי $Y$ כך ש־$X$ הומאומורפי לתת־קבוצה פתוחה של $Y$.\
  בהרצאה ראינו שהמרחב האוסדרוף קומפקטי הוא מרחב מקטגוריה שנייה ולכן $Y$ מקטגוריה שנייה.\
  יהי $x in X$ ומכיוון ש־$X$ פתוח ב־$Y$ הרי ש־$X$ סביבה פתוחה של $x$ ב־$Y$.\
  נניח בשלילה ש־$X$ מקטגוריה ראשונה ולכן קיימת סדרת קבוצות לכל היותר בנות־מנייה $(A_n)_(n=1)^infinity$ כך שלכל $n in NN$, $A_n$ דלילה ב־$X$.\
  מכיוון ש־$X$ פתוחה ב־$Y$ מתקיים
  $ closure(A_n)^X = closure(A_n)^Y inter X ==> emptyset = Int_X (closure(A_n)^X) = Int_X (closure(A_n)^Y inter X) $
  $X$ פתוח ב־$Y$ ולכן הפנים של חיתוך עם $X$ בתת־מרחב $X$ מתלכד עם הפנים ב־$Y$, כלומר
  $ Int_X (closure(A_n)^Y inter X) = Int_Y (closure(A_n)^Y) inter X $
  כלומר $Int_Y (closure(A_n)^Y) inter X = emptyset$ ו־$Int_Y (closure(A_n)^Y)$ קבוצה פתוחה שלא חותכת את $X$.\
  נשים לב ש־$Y = X union (Y without X)$ ולכן $Y = (union.big_(n in NN) A_n) union (Y without X)$.\
  אבך $Y without X$ סגורה כי $X$ קבוצה פתוחה והפנים שלה הוא ריק ב־$Y$ ולכן $Y$ הוא איחוד בן־מנייה של קבוצות בעלי פנים ריק, כלומר איחוד בן־מנייה של קבוצות דלילות, כלומר קבוצה מקטגוריה ראשונה.\
  אבל בהרצאה הוכחנו שמרחב האוסדרוף קומפקטי הוא מרחב מקטגוריה שנייה ולכן זאת סתירה ו־$X$ מקטגוריה שנייה.
]

#question()
יהי $X$ מרחב טופולוגי ונניח שלכל $x in X$ יש סביבה פתוחה $U$ כך ש־$U$ מרחב מקטגוריה שנייה (עם הטופולוגיה המושרית) ונוכיח ש־$X$ מרחב מקטגוריה שנייה.

#proof[
  ניזכר שאומרים שקבוצה $A subset.eq X$ היא מקטגוריה ראשונה אם היא איחוד לכל היותר בן־מנייה של קבוצות דלילות ואחרת אומרים שהיא מקטגוריה שנייה כאשר קבוצה $A$ היא דלילה אם $X without closure(A)$ צפופה ב־$X$.\
  נניח בשלילה אם כך ש־$X$ הוא מרחב מקטגוריה ראשונה ותהיי $I subset.eq NN$ קבוצת האינדקסים כך שלכל $i in I$, $A_i subset.eq X$ תתי־קבוצות הדלילות כך ש־$X = union.big_(i in I) A_i$.\
  יהי $x in X$ ומהנתון קיימת לו סביבה פתוחה $U$ שהיא מקטגוריה שנייה ונסתכל על החיתוך
  $ U = X inter U = (union.big_(i in I) A_i) inter U = union.big_(i in I) (A_i inter U) $
  נשים לב שמהגדרה מתקיים
  $
    closure(A_i inter U)^U subset.eq closure(A_i)^X inter U ==> Int_U (closure(A_i inter U)^U) subset.eq Int_U (closure(A_i)^X inter U)
  $
  אבל $U$ פתוחה ולכן $Int_U (closure(A_i)^X inter U) = U inter Int_X (closure(A_i)^X) = emptyset$
  שכן $A_i$ דלילה ב־$X$ ולכן $A_i inter U$ היא דלילה ב־$U$ אבל זאת כמובן סתירה כי מהנתון $U$ הוא מרחב מקטגוריה שנייה כלומר היא לא איחוד בן־מנייה של קבוצות דלילות למרות שהבנייה לעיל מראה שהוא כן מרחב מקטגוריה ראשונה ולכן $X$ מרחב מקטגוריה שנייה.
]

#question()
נוכיח ש־$QQ$ אינו קומפקטי מקומית.

#proof[
  נניח בשלילה ש־$QQ$ קומפקטי מקומית ולכן עבור $0 in QQ$ קיימת סביבה פתוחה $U subset.eq QQ$ ותת־קבוצה קומפקטית $K subset.eq QQ$ כך ש־$0 in U subset.eq K$.\
  מכיוון ש־$U$ פתוחה ב־$QQ$ קיים $epsilon > 0$ כך שמתקיים $V=(-epsilon, epsilon) inter QQ subset.eq U subset.eq K$ ובפרט הקבוצה הקומפקטית $K$ מכילה את כל המספרים הרציונליים בקטע $(-epsilon, epsilon)$.\
  bcjr $alpha in (-epsilon, epsilon)$ כך ש־$alpha in RR without QQ$ ומצפיפות הרציונליים בממשיים קיימת סדרת רציונליים $(r_n)_(n=1)^infinity subset.eq (-epsilon, epsilon) inter QQ$ כך ש־$r_n arrow alpha$ בטופולוגיה הסטנדרטית של $RR$ ו־$r_n in K$ לכל $n in NN$.\
  $QQ$ מטרזבילי ו־$K$ תת־מרחב מטרזבילי וקומפקטי ולכן הוא קומפקטי סדרתית ומכאן שלסדרה $(r_n)_(n=1)^infinity$ יש תת־סדרה מתכנסת $(r_n_k)_(k=1)^infinity$ המתכנסת לאיבר ב־$K$ אבל הגבול שלנו הוא יחיד ולכן $r_n_k arrow_(k arrow infinity) alpha$ אבל $alpha in.not QQ$ ולכן הגבול לא ב־$QQ$ ובפרט $alpha in.not K$ וזו סתירה לקומפקטיות הסדרתית ולכן $QQ$ אינו קומפקטי מקומית.
]

#question()
תהיי $f:RR arrow RR$ ותהיי $A$ קבוצת נקודות הרציפות של $f$.

#subquestion()
נוכיח ש־$A$ חיתוך בן־מנייה של תתי־קבוצות פתוחות של $RR$.

#proof[
  אם $f$ רציפה אז הטענה טריוויאלית שכן רציפות אומר שהמקור של כל קבוצה פתוחה היא קבוצה פתוחה ואז $A = RR$ ובטופולוגיה הסטנדרטית $RR$ היא קבוצה פתוחה ולכן הוא גם חיתוך בן־מנייה של קבוצות פתוחות עם $U_n = RR$ לכל $n in NN$.\
  נשתמש בהגדרת הרציפות של $delta-epsilon$: $f$ רציפה ב־$x in RR$ אם ורק אם לכל $n in NN$ כאשר $epsilon = 1/n$ קיים $delta>0$ כך שלכל $y,z in (x-delta, x+delta)$ מתקיים
  $ abs(f(y)-f(z))<1/n $
  אז נגדיר
  $ U_n = {x in RR bar exists delta>0 space s.t. space forall y,z in (x-delta,x+delta), space abs(f(y)-f(z))<1/n} $
  נשים לב ש־$U_n$ פתוחה לכל $n in NN$: שכן מהגדרתה קיים $delta > 0$ ונסתכל על הקטע $I=(x-delta, x+delta)$. בקטע זה, לכל $y,z in I$ מתקיים שהמרחק ביניהן קטן מ־$1/n$. נבחר $w in I$ ומכך ש־$I$ קטע פתוח קיימת סביבה פתוחה קטנה יותר סביב $w$ המוכלת כולה בתוך $I$, כלומר קיימת $delta_w > 0$ כך ש־$(w-delta_w, w+delta_w) subset.eq I$ וכל הנקודות האלו הן בפרט בתוך $I$ ולכן המרחק של $f$ עליהן קטן מ־$1/n$ ולכן גם $w in U_n$ וזה בידיוק אומר ש־$U_n$ פתוחה.\
  יתר על־כן, אם $x in A$ אז לכל $n in NN$ קיימת $delta>0$ המקיימת את תנאי הרציפות כלומר $x in inter.big_(n in NN) U_n$. מצד שני, אם $x in inter.big_(n in NN) U_n$, יהי $epsilon > 0$ ונבחר $n in NN$ מספיק גדול כך ש־$1/n < epsilon$ ולכן קיים $delta > 0$ כך שלכל $y,z in (x-delta,x+delta)$ מתקיים שהמרחק ביניהם קטן מ־$1/n$, בפרט עבור $z=x$ ונקבל $abs(f(y)-f(x))<1/n < epsilon$
  וזו בידיוק ההגדרה לרציפות קושי ולכן $x in A$.\
  אז $A = inter.big_(n in NN) U_n$ כלומר היא חיתוך בן־מנייה של תתי־קבוצות פתוחות של $RR$.
]

#subquestion()
נסיק שאם $A$ צפופה אז היא אינה בת־מנייה ונסיק ש־$QQ$ אינה יכולה להיות קבוצת נקודות רציפות של אף פונקציה $RR arrow RR$.

#proof[
  נניח ש־$A$ צפופה ב־$RR$. מהסעיף הקודם $A = inter.big_(n in NN) U_n$ ו־$U_n$ פתוחה ב־$RR$ ומכך ש־$A subset.eq U_n$ לכל $n in NN$ ו־$A$ צפופה ב־$RR$ נובע ש־$U_n$ פתוחה וצפופה ב־$RR$.\
  אם בשלילה $A$ היא בת־מנייה אז $A={a_1, a_2, a_3, dots.h}$ ולכל $k in NN$ נגדיר $F_k = RR without {a_k}$ ולכן $F_k$ גם פתוחה וצפופה ב־$RR$ (כי ${a_k}$ הוא יחידון סגור בעל פנים ריק) ונשים לב שמתקיים
  $ inter.big_(n in NN) U_n inter inter.big_(k in NN) F_k = A inter (RR without A) = emptyset $
  אבל $RR$ מרחב מטרי שלם ולכן ממשפט הקטגוריה של בייר חיתוך בן־מנייה של תתי־קבוצות פתוחות וצפופות בו הוא צפוף ב־$RR$ ובפרט אינו ריק ולכן קיבלנו סתירה למשפט הקטגוריה של בייר ולכן אם $A$ צפופה היא לא בת־מנייה.\
  עבור ההסקה השנייה, נניח בשלילה שקיימת $f:RR arrow RR$ כך ש־$A=QQ$. מצפיפות $QQ$ ב־$RR$ מהמסקנה לעיל נובע ש־$A$ לא בת־מנייה וזו סתירה להיות $A=QQ$ ולכן לא קיימת פונקציה כזאת.
]

#question()
יהי $X$ מרחב האוסדרוף קומפקטי מקומית. יהיו $Y_1, Y_2$ מרחבי האוסדרוף קומפקטיים שהם קומפקטיפיקציות חד־נקודתיות של $X$ (כלומר עבור $i=1,2$, $Y_i$ קומפקטי, מכיל תת־מרחב $X^prime$ צפוף שהומאומורפי ל־$X$ כך ש־$Y_i without X^prime$ הוא סינגלטון). נוכיח כי $Y_1$ הומאומורפי ל־$Y_2$.

#proof[
  לפי הרמז המרחב שבנינו בהרצאה היה $Y_2 = X union {infinity}$ יחס עם הטופולוגיה
  $ hat(T) = T_X union {Y_2 without C bar C subset.eq X "closed and compact"} $
  יהי $Y_1$ מרחב האוסדורף קומפקטי המהווה קומפקטיפיקציה חד־נקודתית של $X$. כלומר, $X$ מוכל בו כתת־מרחב פתוח וצפוף, וקיים $p_1 in Y_1$ כך ש־$Y_1 without X = \{p_1\}$.\
  נגדיר $f: Y_1 arrow Y_2$ על־ידי
  $ f(y) = mycases(y, y in X, infinity, y=p_1) $
  מהגדרה, $f$ חד־חד ערכית ועל. נראה שהיא גם רציפה – תהיי $v in hat(T)$.\
  אם $v in T_X$ אז $f$ העתקת הזהות על $X$ ולכן $f^(-1)(V) = V$ והעתקת הזהות רציפה. אחרת, $V=Y_2 without C$ עבור $C subset.eq X$ קומפקטית וסגורה ב־$X$ ו־$infinity in V$ ולכן בהכרח $p_1 in f^(-1)(V)$. יתר על־כן
  $ f^(-1)(V)=f^(-1)(Y_2 without C) = Y_1 without f^(-1)(C) = Y_1 without C $
  נשים לב ש־$C$ קומפקטית ב־$X$ ולכן קומפקטית ב־$Y_1$ ו־$Y_1$ מרחב האוסדורף ולכן $C$ קבוצה סגורה גם ב־$Y_1$ ולכן $Y_1 without C$ זה המשלים של $C$ ב־$Y_1$ והמשלים של קבוצה סגורה היא פתוחה. אז $f$ רציפה.\
  אז $Y_1$ הומיאומורפי ל־$Y_2$.\
  הערה: מספיק לקבע אחת מהן להיות הקומפקטיפיקציה הסטנדרטית X∪{∞}, ולהראות שכל קומפקטיפיקציה חד־נקודתית אחרת שקולה לה ולכן יכולנו להשתמש בבנייה של $Y_2$ מההרצאה.
]

#question()
יהי $X$ מרחב האוסדרוף קומפקטי מקומית.\
נגיד ש־$k$־כוכב ב־$X$ הוא אוסף ${U_i}_(i=1)^k$ של תתי־קבוצות פתוחות של $X$ כך שמתקיים
+ $U_i inter U_j = emptyset$ לכל $i!=j$
+ $Y= X without (union.big_(i=1)^k U_i)$ קומפקטית
+ לכל $1<=i<=k$ מתקיים ש־$Y union U_i$ אינה קומפקטית

#subquestion()
נניח של־$X$ יש קומפקטיפיקציה $k$ נקודתית $Z$ שמקיימת את תנאי האוסדרוף (כלומר $Z$ מרחב האוסדרוף קומפקטי כך ש־$X subset.eq Z$, $X$ צפוף ב־$Z$ ו־$Z without X = {z_1, dots.h, z_k}$).\
נוכיח שקיימות סביבות פתוחות $V_1, dots.h, V_k$ של $z_1, dots.h, z_k$ כך ש־$V_i inter V_j = emptyset$ עבור $i!=j$.\
עבור $V_1, dots.h, V_k$ כאלה, הקבוצות $U_i = V_i inter X$ מקיימות ש־${U_i}_(i=1)^k$ הוא $k$־כוכב ב־$X$.

#proof[
  מרחב האוסדרוף קומפקטי זה מרחב בו כל הנקודות ניתנות להפרדה, בפרט עבור ${z_1, dots.h, z_k}$ קיימות סביבות פתוחות $V_1, dots.h, V_k subset.eq Z$ זרות בזוגות ו־$z_i in V_i$.\
  נגדיר $U_i = V_i inter X$ ונראה שזה מקיים את תנאי ה־$k$־כוכב.\
  מכך ש־$V_i$ פתוחות ב־$Z$ אז $U_i$ פתוחות ב־$X$ ומהזרות מתקיים $U_i inter U_j = (V_i inter V_j) inter X = emptyset inter X = emptyset$.\
  נסמן $Y=X without (union.big_(i=1)^k U_i)$ ו־$X=Z without {z_1, dots.h, z_k}$ אז הרי ש־$Z without (union.big_(i=1)^k V_i) subset.eq X$ ולכן $Y=X without (union.big_(i=1)^k V_i)=Z without (union.big_(i=1)^k V_i)$.\
  כל $V_i$ פתוחה ב־$Z$ ולכן גם האיחוד שלהן פתוח ב־$Z$ והמשלים שלהן הוא קבוצה סגורה בתוך המרחב הקומפקטי $Z$, אבל תת־קבוצה סגורה של מרחב קומפקטי היא גם קבוצה קומפקטית ולכן $Y$ קבוצה קומפקטית ב־$Z$.\
  נשאר להראות את התנאי האחרון – נניח בשלילה שקיים אינדקס $i$ כך ש־$Y union U_i$ קומפקטית ב־$X$ ולכן היא גם קומפקטית ב־$Z$ שהוא האוסדרוף ולכן $Y union U_i$ היא קבוצה סגורה ב־$Z$ ו־$X$ צפוף ב־$Z$ ולכן $z_i in closure(X)^Z$ (הסגור של $X$ ב־$Z$).\
  מהיות $V_i$ סביבה פתוחה של $z_i$ ולכן היא חייבת לחתוך את $X$ בכל סביבה של $z_i$ כלומר $z_i in closure(V_i inter X)^Z = closure(U_i)^Z$ ולכן $z_i in closure(Y union U_i)^Z$ (הרי שאם נקודה נמצאת בסגור של קבוצה היא נמצאת גם בסגור של קבוצה גדולה יותר שמכילה אותה) אבל האחרונה סגורה ולכן $z_i in Y union U_i subset.eq X$ בסתירה לכך ש־$z_i in.not X$ כלומר לכל $i$ מתקיים\
  ש־$Y union U_i$ לא קומפקטית.
]

#subquestion()
יהי ${U_i}_(i=1)^k$ הוא $k$־כוכב ב־$X$ ונסמן $Y=X without (union.big_(i=1)^k U_i)$. נוכיח שלכל $1<=i <=k$ הקבוצה $Y union U_i$ אינה מוכלת באף תת־קבוצה קומפקטית של $X$.

#proof[
  מהגדרת ה־$k$־כוכב, $U_1, dots.h, U_k$ זרות זו לזו ונסמן את המשלים שלהן ב־$X$ ב־$Y$ ואז $X=Y union (union.big_(i=1)^k U_i)$.\
  מתקיים $Y union U_i = X without (union.big_(j!=i) U_j)$ ומהיות $U_i$ פתוחות אז גם $union.big_(j!=i) U_j$ קבוצה פתוחה ב־$X$ ולכן המשלים שלה שזה בידיוק $Y union U_i$ היא קבוצה סגורה ב־$X$.\
  נניח בשלילה שקיימת תת־קבוצה קומפקטית $K subset.eq X$ כך שמתקיים $Y union U_i subset.eq K$ ומכך ש־$Y union U_i$ קבוצה סגורה בתוך קבוצה קומפקטית היא קבוצה קומפקטית ולכן אבל זו סתירה לתנאי השלישי בהגדרת $k$־כוכב.
]

#subquestion()
נסיק של־$RR$ אין קומפקטיפיקציה $3$־נקודתית.

#proof[
  נניח בשלילה שכן קיים 3־כוכב ב־$RR^3$ ולכן קיימות $U_1, U_2, U_3$ פתוחות זרות בזוגות כך ש־$Y=RR without (union_(i=1)^k U_i)$ היא קבוצה קומפקטית ב־$RR$.\
  קבוצה קומפקטית ב־$RR$ לפי משפט היינה בורל היא קבוצה סגורה וחסומה ולכן קיים $M>0$ כך ש־$Y subset.eq [-M, M]$ ונתבונן ב־$union.big_(i=1)^3 U_i$ ומהגדרת הישר הממשי נובע כי $(-infinity, -M), (M, infinity) subset.eq union.big_(i=1)^3 U_i$.\
  שני קטעים אלו הם הרכיבים הקשירים הלא חסומים היחידים של האיחוד (כל השאר אם הם קיימים הם חסומים ב־$[-M, M]$).\
  מהיות הקבוצות זרות זו לזו נובע כי רכיב קשירות של המשלים $RR without Y$ נמצא בידיוק באחת מן הקבוצות. יש לנו $2$ רכיבי קשיורת לא חסומים ו־$3$ קבוצות פתוחות ולכן לפי עיקרון שובך היונים לכל הפחות אחת מהן ובלי הגבלת הכלליות זו $U_3$ לא מכילה אף אחד משני רכיבי הקשירות הלא חסומים ולכן $U_3$ מורכבת אך ורק מרכיבי קשירות חסומים שכולם ב־$[-M, M]$ ולכן $U_3 subset.eq [-M, M]$ אבל גם $Y subset.eq [-M, M]$ ולכן $Y union U_3 subset.eq [-M, M]$ וזו קבוצה שמוכלת בתת־קבוצה קומפקטית של $RR$ (כי היינה בורל זה אם ורק אם) אבל זאת סתירה של השאלה הקודמת ולכן אין ל־$RR$ קומפקטיפיקציה $3$־נקודתית.
]

#subquestion()
נניח ש־${U_i}_(i=1)^k$ כוכב ב־$X$ ונסמן $Y = X without (union.big_(i=1)^k U_i)$. נסמן ב־$tau_X$ את הטופולוגיה על $X$ ונוכיח ש־$Z=X union {z_1, dots.h, z_k}$ יחד עם הטופולוגיה
$
  tau_Z = tau_X union {W union {z_i} bar 1<=i<=k, space W in tau_X, space (Y union U_i) inter (X without W) "is compact"}
$
היא קומפקטיפיקציה $k$־נקודתית ל־$X$ ומקיים את תנאי האוסדרוף.

#proof[
  נזכר ש־$A without B = A inter (X without B)$ ועלינו להראות שלושה דברים: $Z$ מרחב האוסדרוף, $X$ צפוף ב־$Z$ ו־$Z$ הוא מרחב קומפקטי.
  + $Z$ הוא מרחב האוסדורף: תהיינה שתי נקודות שונות ב־$Z$.\
    יש לנו שלוש אפשרויות שונות
    + שתי נקודות מ־$X$: מהיות $X$ הוא מרחב האוסדורף נובע שקיימות להן סביבות זרות ב־$tau_X$. סביבות אלו מוכלות גם ב־$tau_Z$ וסיימנו.
    + נקודה $x in X$ ונקודה $z_i$: מכיוון ש־$X$ קומפקטי מקומית, קיימת ל־$x$ סביבה פתוחה $V subset.eq X$ שהסגור שלה, $K$, הוא קומפקטי ב־$X$.\
      נגדיר $W = X without K$ וזו קבוצה פתוחה ב־$X$.\
      נבדוק את הסביבה $O_i = W union \{z_i\}$ ומתקיים $(Y union U_i) without W = (Y union U_i) inter K$. משאלה 2 נקבל ש־$Y union U_i$ היא קבוצה סגורה ב־$X$ לכן החיתוך שלה עם הקבוצה הקומפקטית $K$ מייצר קבוצה קומפקטית ומכאן ש־$O_i in tau_Z$.\
      מכיוון ש־$V subset.eq K$ ו־$W = X without K$, הרי ש־$V inter O_i = V inter W = emptyset$ והנקודות הופרדו.
    + שתי נקודות $z_i != z_j$: נגדיר את הסביבות $O_i = U_i union \{z_i\}$ ו־$O_j = U_j union \{z_j\}$. \
      אם נציב $W = U_i$ בבדיקת הקומפקטיות:$(Y union U_i) without U_i = Y without U_i = Y$ ונתון לנו ש־$Y$ קומפקטית לכן, $O_i$ וכן $O_j$ הן סביבות פתוחות.\
      מכיוון שתנאי ה־$k$־כוכב הראשון מבטיח ש־$U_i inter U_j = emptyset$, החיתוך של שתי הסביבות ריק והנקודות הופרדו.
  + $X$ צפוף ב־$Z$: אם בשלילה $O_i inter X = emptyset$, הרי שבהכרח $W = emptyset$. אבל, אם נציב זאת בתנאי של הטופולוגיה נדרוש ש־$(Y union U_i) without emptyset = Y union U_i$ יהיה קומפקטי.\
    אבל תנאי 3 של ה־$k$־כוכב אומר בדיוק ש־$Y union U_i$ אינה קומפקטית ולכן כל סביבה חותכת את $X$ ו־$X$ צפופה.
  + $Z$ הוא מרחב קומפקטי: יהי $cal(O)$ כיסוי פתוח של $Z$.\
    על מנת לכסות את הנקודות החדשות $z_1, dots.h, z_k$, הכיסוי חייב לכלול קבוצות מהצורה $O_i = W_i union \{z_i\}$ עבור כל $1 <= i <= k$.\
    מהגדרת הטופולוגיה הקבוצה $C_i = (Y union U_i) without W_i$ היא קומפקטית ב־$X$.\
    נבחן אילו נקודות של $X$ (כלומר של $Z$) לא מכוסות על־ידי איחוד הקבוצות $O_1, dots.h, O_k$.\
    מתקיים ש־ $Z without (union.big_(i=1)^k O_i) = X without (union.big_(i=1)^k W_i)$ ונשים לב שממהגדרת ה־$k$־כוכב נובע ש־$X = Y union (union.big_(i=1)^k U_i) = union.big_(i=1)^k (Y union U_i)$.\
    לכן $X without (union.big_(i=1)^k W_i) subset.eq union.big_(i=1)^k ((Y union U_i) without W_i) = union.big_(i=1)^k C_i$ ומכיוון שכל אחת מ־$C_i$ היא קומפקטית, והאיחוד הוא סופי, הרי שהאיחוד $union.big_(i=1)^k C_i$ הוא קבוצה קומפקטית (ממשפט טיכונוף).\
    אז החלק של $Z$ שלא כוסה עד כה מוכל בתוך תת־קבוצה קומפקטית, ומכאן שניתן לכסות אותו על ידי מספר סופי של קבוצות מתוך הכיסוי המקורי $cal(O)$.\
    יחד עם $k$ הסביבות $O_i$ שבחרנו בהתחלה, קיבלנו תת־כיסוי סופי המכסה את המרחב כולו, ולכן $Z$ מרחב קומפקטי.
]
