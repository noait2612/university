#question()
יהי $X$ מרחב טופולוגי כך שלכל $f:X arrow X$ רציפה יש נקודת שבת ויהי $Y$ מרחב טופולוגי אשר הומיאומורפי אל $X$.\
נוכיח שלכל $g:Y arrow Y$ רציפה יש נקודת שבת.

#proof[
  $X$ ו־$Y$ הומיאומורפים ולכן קיימת $phi : X arrow Y$ הומיאומורפיזם ו־$phi^(-1) : Y arrow X$ גם־כן הומיאומורפיזם ותהיי $g : Y arrow Y$ רציפה.\
  נגדיר $f : X arrow X$ על־ידי $f(x) = phi^(-1)(g(phi(x))))$, זו פונקציה רציפה כהרכבת פונקציות רציפות ולכן מההנחה יש לה נקודת שבת $x_0 in X$ ולכן מתקיים $f(x_0) = x_0$.\
  נסמן $y_0 = phi(x_0)$ ונרצה להראות ש־$g(y_0) = y_0$ ואכן מתקיים
  $ g(y_0) = g(phi(x_0))= phi(f(phi^(-1)(phi(x_0)))) = phi(f(x_0)) = phi(x_0) = y_0 $
]

#question()
נוכיח כי הסימפלקס הדו־מימדי
$ Delta^2 colon.eq {vec(x, y, z) in RR^3 bar x,y,z >=0, x+y+z = 1} $
הומיאומורפי אל דיסק היחידה הדו־מימדי $DD^2 colon.eq {(x,y) in RR^2 bar x^2+y^2 <= 1}$.

#proof[
  ראשית נגדיר
  $ T={(x,y) in RR^2 bar x>=0, y>=0, x+y<=1} $
  זה משולש ישר זווית ונגדיר $f: Delta^2 arrow T$ על־ידי
  $ f(x, y, z) = (x,y) $
  זוהי פונקציה רציפה (כצמצום של ההטלה הסטנדרטית) והיא גם חד־חד־ערכית על $Delta^2$ שכן הקורדינאטה השלישית נקבעת ביחידות על־ידי שתי הקורדינאטות הראשונות שהרי $z=1-x-y$.\
  ונגדיר $f^(-1) : T arrow Delta^2$ על־ידי
  $ f^(-1)(x,y)=(x,y,1-x-y) $
  לכל $(x,y) in T$ מתקיים $x+y<=1$ ולכן $1-x-y>=0$ וסכום הרכיבים הוא תמיד $1$ ולכן התמונה של הפונקציה מוכלת ב־$Delta^2$ ו־$f^(-1)$ מורכבת מפולינומים בכל קורדינאטה ולכן רציפה.\
  מצאנו פונקציה שגם היא וגם ההופכית שלה רציפות ולכן $f$ הומיאומורפיזם ומתקיים $Delta^2 tilde.equiv T$.\
  נראה ש־$T tilde.equiv DD^2$.\
  נבחר נקודה פנימית במשולש $T$ כמו את מרכז הכובד שלו $c=(frac(1, 3), frac(1, 3))$ ונגדיר משולש מוזז $T_0$ כך שראשית הצירים תהיה בפנים שלו על־ידי העתקת ההזה
  $ g(x,y)=(x-frac(1, 3), y-frac(1, 3)) $ זו הזזה ולכן $T tilde.equiv T_0$.\
  $T_0$ הוא קבוצה קומפקטית וקמורה ב־$RR^2$ המכילה את הראשית. לכל $u in S^1$ הקרן היוצאת מהראשית בכיוון $u$ חותכת את $boundary(T_0)$ בנקודה יחידה.\
  נסמן את המרחק מהראשית לנקודת חיתוך זו ב־$r(u)$ אבל זו פונקציה $r:S^1 arrow RR_(>0)$ רציפה שכן שפת המשולש מורכבת מקטעים לינאריים למקוטעין החסומים במרחק חיובי מהראשית.\
  נגדיר
  $ h(v)=mycases(0, v =0, frac(norm(v), r(frac(v, norm(v)))) dot.op frac(v, norm(v)), v!=0) $
  הפונקציה $h$ לוקחת כל קטע המחבר את הראשית לנקודה על שפת המשולש, ומכווצת או מותחת אותו באופן לינארי כך שאורכו יהיה בדיוק 1. כלומר, היא ממפה את שפת המשולש לשפת הדיסק, ואת פנים המשולש לפנים הדיסק.\
  $h$ רציפה לכל $v!=0$ כהרכבה של פונקציות חיוביות והרציפות בראשית בראשית מובטחת שכן $r(u)$ חסומה מלמטה על ידי קבוע חיובי כלשהו (זאת מכוון ש־$S^1$ קומפקטית ו־$r$ חיובית ממש), ולכן $norm(h(v)) stretch(arrow)_(v arrow 0) 0$.\
  ואכן, זו גם פונקציה חד־חד ערכית ועל. החד־חד ערכיות נובעת ישירות מהגדרה, העל קצת מסובך יותר: אם $w in DD^2$, אם $w=0$ אז $v=0$ מסיים. אחרת, נסמן $u=frac(w, norm(w))$ ו־$norm(w)=s$ מתקיים $0<s<=1$.\
  אנחנו מחפשים $v$ שיהיה מאותו כיוון של $w$ כלומר $v=c dot.op u$ עבור $c>0$ סקלר ונדרוש שיתקיים $h(v)=u$, אז
  $ h(c dot.op u)=frac(c, r(u)) u = s dot.op u $
  מכאן נובע שעלינו לבחור $c=s dot.op r(u)$ ואז $v=(s dot.op r(u))u = s dot.op (r(u)u)$ אבל $r(u)u$ נמצאת בידיוק על השפה לפי הגדרת $r$ ומכך ש־$0<s<=1$, $v$ נמצאת על הקטע הישר המחבר את הראשית עבור $s=0$ לבין נקודת השפה $r(u)u$ עבור $s=1$.\
  $T_0$ היא קבוצה קמורה ולכן כל הקטע הזה מוכל ב־$T_0$ מהגדרת הקמירות ואז $v in T_0$ וקיבלנו על, כנדרש.\
  מצאנו פונקציה רציפה, חד־חד ערכית ועל ממרחב קומפקטי ($T_0$) למרחב האוסדרוף ($DD^2$) ולכן מטענה שראינו זה הומיאומורפיזם וקיבלנו שרשרת הומיאומורפיזמים ולכן $Delta^2 tilde.equiv DD^2$.
]

#question()
תהיי $(a_(i j))_(i, j in [3]) = A in M_(3 times 3) (RR)$ מטריצה ממשית הפיכה ונניח כי $a_(i j) >=0$ לכל $i,j in [3]$. נוכיח שקיים ערך עצמי חיובי עבור $A$.

#proof[
  נסמן
  $ Delta^2 = {v in RR^3 bar v_i >= 0 "לכל " i=1,2,3, space sum_(i=1)^3 v_i = 1} $
  מהשאלה הקודמת $Delta^2$ הומיאומורפי ל־$DD^2$.\
  לכל $u in RR^3$ יש את נורמת הסכום (הרגילה של $ell_1$) ב־$norm(u)_1$ ואם כל הרכיבים הם אי־שליליים מתקיים
  $ norm(u) = abs(u_1) + abs(u_2) + abs(u_3) = u_1 + u_2 + u_3 $
  נגדיר $f:Delta^2 arrow RR^3$ על־ידי
  $ f(v) = frac(A v, norm(A v)_1) $
  זו פונקציה רציפה – שכן סכום רכיבי $v$ הם $1$ והמטריצה היא הפיכה ולכן היא שולחת את וקטור האפס רק לוקטור האפס ועל־כן $A v != 0$.\
  בנוסף, נתון שלכל $i, j in [3]$ מתקיים $a_(i j) >=0$ ולכל $j in [3]$ מתקיים $v_j >= 0$ ולכן כל רכיב בוקטור $A v$ הוא סכום של מכפלות אי־שליליות ולכן אי־שלילי ובפרט לפחות אחד מרכיביו יהיה חיובי ממש ולכן סכום הרכיבים חיובי ממש כלומר $norm(A v)_1 > 0$ ולכן החלוקה מוגדרת היטב.\
  $f$ רציפה כהרכבה של פונקציות רציפות (העתקה לינארית, נורמה וחלוקה במכנה שאינו מתאפס).\
  נסתכל על $w=f(v)=frac(A v, norm(A v)_1)$ עבור $v in Delta^2$ ו־$w$ אי־שלילי מהנימוקים לעיל, אז מתקיים
  $
    sum_(i=1)^3 w_i=sum_(i=1)^3 frac((A v)_i, norm(A v)_1) = frac(1, norm(A v)_1) sum_(i=1)^3 (A v)_i = frac(1, norm(A v)_1) norm(A v)_1 = 1
  $
  כלומר לכל $v in Delta^2$ מתקיים $f(v) in Delta^2$ ולכן $f:Delta^2 arrow Delta^2$ רציפה.\
  מכיוון ש־$f$ היא פונקציה רציפה ממרחב ההומיאומורפי לדיסק סגור ($Delta^2$) אל תוך עצמו, ממשפט נקודת השבת של בראואר נובע כי קיימת ל־$f$ נקודת שבת,
  כלומר, קיים וקטור $v^* in Delta^2$ כך שמתקיים $f(v^*) = v^*$ ואז
  $ (A v^*) / norm(A v^*)_1 = v^* <==> A v^* = norm(A v^*)_1 dot.op v^* $
  נגדיר $lambda = norm(A v^*)_1$. ממה שראינו לעיל מתקיים $norm(A v^*)_1 > 0$, ולכן $lambda > 0$ וכמו־כן מתקיים $v^* in Delta^2$ ולכן $v^* != 0$.\
  קיבלנו משוואה מהצורה $A v^* = lambda v^*$, עם $v^* != 0$ ו־$lambda > 0$ כלומר $lambda$ הוא ערך עצמי חיובי של המטריצה $A$, כנדרש.
]

#question()
תהיי $f:SS^2 arrow SS^2$ פונקציה רציפה כך ש־$f(x)!=f(-x)$ לכל $x in SS^2$ ונוכיח כי $f$ היא פונקציה על.

#proof[
  נניח ש־$f$ לא על ולכן קיים $x_0$ כך ש־$x in.not f(SS^2)$ ולכן נסתכל על $tilde(f) : SS^2 arrow SS^2 without {x_0}$ ומהנתון $tilde(f)$ עדיין רציפה (ובפרט $f eq.triple tilde(f)$).\
  בהרצאה ראינו ש־$SS^2 without {x_0} tilde.equiv RR^2$ ולכן קיים הומיאומורפיזם $phi : SS^2 without {x_0} arrow RR^2$ ולכן נסתכל על ההרכבה $g:SS^2 arrow RR^2$ הנתונה על־ידי $g = phi compose tilde(f)$ וממשפט בורסוק־אולם קיים $x in SS^2$ עבורו $g(x)=g(-x)$ אבל בבירור זאת סתירה שכן
  $ g(x) = g(-x) <==> f(x) = f(-x) $
  שכן $phi$ חד־חד ערכית וזאת בסתירה לנתון.
]

#question()
יהיו $A_1, A_2, A_3 subset.eq SS^2$ תתי־קבוצות סגורות המכסות את $SS^2$ ונוכיח כי קיים $x in SS^2$ ו־$i in [3]$ עבורם ${x, -x} subset.eq A_i$.

#proof[
  נרצה שוב להשתמש במשפט בורסוק־אולם.\
  נגדיר $f:SS^2 arrow RR^2$ על־ידי
  $ f(x) = (d(x, A_1), d(x, A_2)) $
  כאשר $d(x, A) = inf_(a in A) d(x, a)$ היא פונקציית המרחק מקבוצה שרציפה ולכן $f$ רציפה כי כל רכיבייה רציפים.\
  לפי משפט בורסוק־אולם לכל פונקציה רציפה $g:SS^2 arrow RR^2$ קיימת $x in SS^2$ עבורה $g(x)=g(-x)$ ובמקרה שלנו עבור $f$ מתקיים
  $ d(x, A_1) = d(-x, A_1) quad "וגם" quad d(x, A_2) = d(-x, A_2) $
  נחלק למקרים
  + נניח ש־$d(x, A_1) = 0$. מכיוון ש־$A_1$ היא קבוצה סגורה, המרחק של נקודה ממנה הוא אפס אם ורק אם הנקודה שייכת אליה ולכן $x in A_1$.\
    מאחר ש־$d(-x, A_1) = d(x, A_1) = 0$, נובע שגם $-x in A_1$. קיבלנו ש־${x, -x} subset.eq A_1$.
  + נניח ש־$d(x, A_2) = 0$. מאותם שיקולים לעיל של סגירות נקבל $x in A_2$ וגם $-x in A_2$ ולכן ${-x, x} subset.eq A_2$.
  + נניח ש־$d(x, A_1) > 0$ וגם $d(x, A_2) > 0$. מההנחה נובע ש־$x in.not A_1$ וגם $x in.not A_2$ אבל נתון ש־$A_1 union A_2 union A_3 = SS^2$ ולכן $x in A_3$.\
    באופן  דומה גם $d(-x, A_1) > 0$ וגם $d(-x, A_2) > 0$ ולכן $-x in.not A_1$ וגם $-x in.not A_2$ מה ששוב מחייב $-x in A_3$.\
    כלומר קיבלנו שבמקרה זה מתקיים ${x,-x} subset.eq A_3$.
  כלומר בכל מקרה קיים $i in [3]$ עבורו ${x, -x} subset.eq A_i$, כנדרש.

]

