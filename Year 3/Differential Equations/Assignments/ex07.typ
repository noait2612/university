#question()
נתבונן במערכת המשוואות
$ vec(x^prime, y^prime)=vec(y, -y-sin(x)) $

#subquestion()
נמצא את נקודות שיווי המשקל של המערכת.

#solution[
  כדי למצוא נקודות שיוויון משקל אנחנו צריכים שיתקיים $ cases(x^prime = 0, y^prime = 0) $
  אז $y=0$ ברור ולכן נשאר ש־$sin(x)=0$ וזה קורה עבור $k pi$ לכל $k in ZZ$.\
  כלומר נקודות שיווי המשקל הן כל הנקודות מהצורה $(k pi, 0)$ עבור $k in ZZ$.\
]

#subquestion()
נקבע את היציבות (לא אסימפטוטית) של נקודות שיווי המשקל.

#solution[
  ראשית
  $ D F_((x,y)) = mat(0, 1; -cos(x), -1) $
  מהמחזוריות של פונקציית קוסינוס עלינו לחלק לשני מקרים
  + אם $k$ זוגי כלומר $x=2pi m$ עבור $m in NN$: במקרה זה $cos(x)=1$ ולכן המטריצה שלנו היא
    $ A=mat(0, 1; -1, -1) $
    והפולינום האופייני אם כך הוא
    $ lambda^2+lambda+1 = 0 $
    והשורשים שלו הם $lambda=(-1 plus.minus i sqrt(3))/2$ ולשני הערכים העצמיים יש חלק ממשי שלילי ממש ולכן לפי הקריטריון הלינארי ליציבות אסימפטוטית נובע שנקודות אלו יציבות.
  + אם $k$ אי־זוגי כלומר $x=pi(2m+1)$ עבור $m in NN$: במקרה זה $cos(x)=-1$ ולכן המטריצה שלנו היא
    $ A = mat(0, 1; 1, -1) $
    הפולינום האופייני אם כך הוא
    $ lambda^2+lambda-1 = 0 $
    והשורשים שלו הם $lambda=(-1 plus.minus sqrt(5))/2$ אבל יש לנו ערך עצמי חיובי ממש ולכן לפי הקריטריון הלינארי לאי־יציבות נובע שנקודות אלו לא יציבות.
]

#question()
נתבונן במערכת המשוואות הדיפרנציאליות
$ cases(x^prime = (1-y-2x)x, y^prime = (x-1-y)y) $


#subquestion()
נניח כי $(x_0, y_0)$ תנאי התחלה שנמצא על אחד הצירים (כלומר אחת הקואורדינטות היא אפס).\
נבחן מהו הפתרון למערכת המשוואות הנתונה שזה תנאי ההתחלה שלו ונשווה את הפתרון לפתרון המקביל במודל לוקה־וולטרה.

#proof[
  אם תנאי ההתחלה נמצא על ציר ה־$x$ (כלומר $y_0 = 0$, כלומר אין טורפים) אז $y^prime = 0$ ולכן האוכלוסייה $y(t)=0$ תמיד ועבור $x$ המשוואה הופכת להיות \
  $x^prime = x-2x^2$ ולכן $-2x^2$ מאט את קצב הגידול של $x^prime$ והוא הופך להיות משמעותי יותר, כלומר האוכלוסייה לא יכולה לחצות את הרף של $x=1/2$ כי אז הנגזרת תהיה שלילית ותתייצב על ערך זה וזו משוואה לוגיסטית.\
  במודל לוקה־וולטרה מהתרגול אם אין טורפים אוכלוסיית הנטרפים גדלה אקספוננציאלית ומתפוצצת לאינסוף אבל המודל החדש מציאותי יותר כי הוא מונע את הפיצוץ בעזרת הגבת משאבים.\
  אם תנאי ההתחלה נמצא על ציר ה־$y$ (כלומר $x_0 = 0$, כלומר אין נטרפים) אז $y^prime = -y-y^2$ אבל זו בעצם אוכלוסיית טורפים שאין לה מה לאכול ולכן גם האיבר $-y^2$ גורם לכך שככל שיש יותר טורפים קצב התמותה שלהם מואץ (הם מתחרים זה בזה או פוגעים אחד בשני כי אין מזון) והאוכלוסייה פשוט תדעך ותיכחד (תשאף ל־$0$).\
  במודל לוקה־וולטרה הטורפים גוועים ברעב ודועכים לאפס בצורה מעריכה אבל במודל החדש אם יש כמות גדולה של טורפים בהתחלה הם ימותו הרבה יותר מאשר במודל הרגיל (from obvious reasons) ובפרט אולי מהר יותר מהדעיכה המעריכית.
  $$
]

#subquestion()
נמצא את 4 נקודות שיווי המשקל של המערכת.

#solution[
  נפתור את מערכת המשוואות
  $ cases(y(x-1-y) = 0, x(1-y-2x) = 0) $
  כמובן הפיתרון הטריוויאלי $y=x=0$ מתאים כאן.\
  אם $x=0$ ו־$y!=0$ אז
  $ y(-1-y) = 0 <==>_(y!=0) -1-y = 0 <==> y= -1 $
  כלומר $(0,-1)$ היא נקודת שיווי משקל.\
  אם $x!=0$ ו־$y=0$ אז באופן דומה
  $ x(1-y-2x)= 0 <==>_(x!=0) 2x=1 <==> x=1/2 $
  כלומר $(1/2, 0)$ היא נקודת שיווי משקל.\
  נשארה האופציה ש־$x,y!=0$ ונפתור את מערכת המשוואות הלינארית
  $ cases(x-1-y = 0, 1-y-2x = 0) ==> x-1-y-(1-y-2x) = 0 <==> x-2+2x = 0 <==> 3x = 2 <==> x=2/3 ==> y = -1/3 $
  כלומר הנקודה $(2/3, -1/3)$ היא גם נקודת אי־יציבות.
]

