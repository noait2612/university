#subquestion()
נצייר על־גבי מערכת צירים $x y$ את הקווים ${y^prime = 0}, {x^prime = 0}$ ונסמן על־גבי הרביע הראשון את התחומים בהם $x^prime > 0, x^prime < 0, y^prime > 0, y^prime < 0$.

#proof[
  ברביע הראשון $(x,y>0)$ הישר $y=x-1$ מתקיים רק כאשר $x>=1$ והישר $y=1-2x$ מתקיים רק עבור $x<=1/2$.\
  מתחת לישר $y=x-1$ נקבל $y^prime > 0$ ומעליו $y^prime < 0$. מתחת לישר $y=1-2x$ נקבל $x^prime > 0$ ומעליו $x^prime < 0$.\
  קישורי הציור שלי ב־typst מוטלים בספק.
  #import "@preview/cetz:0.5.0": canvas, draw

  #align(center)[ #canvas({
      import draw: *

      // הגדרת קנה מידה: כל יחידה שווה 3 ס"מ בציור כדי שיהיה מרווח וברור
      let scale = 3

      // ציור צירים (כולל החלק השלילי כדי לראות את נקודת החיתוך)
      line((-1 * scale, 0), (2.5 * scale, 0), mark: (end: ">"), stroke: 1pt) // ציר X
      line((0, -1.5 * scale), (0, 2.5 * scale), mark: (end: ">"), stroke: 1pt) // ציר Y

      content((2.6 * scale, 0), $x$)
      content((0, 2.6 * scale), $y$)

      // שנתות על הצירים
      content((-0.3, -0.3), $0$)

      line((1 * scale, -0.1), (1 * scale, 0.1), stroke: 0.5pt)
      content((1 * scale, -0.4), $1$)

      line((2 * scale, -0.1), (2 * scale, 0.1), stroke: 0.5pt)
      content((2 * scale, -0.4), $2$)

      line((-0.1, 1 * scale), (0.1, 1 * scale), stroke: 0.5pt)
      content((-0.4, 1 * scale), $1$)

      line((-0.1, -1 * scale), (0.1, -1 * scale), stroke: 0.5pt)
      content((-0.4, -1 * scale), $-1$)

      // קו x' = 0 (המשוואה y = 1 - 2x) - בצבע כחול
      line((-0.5 * scale, 2 * scale), (1.25 * scale, -1.5 * scale), stroke: blue + 1.5pt)
      content((0.7 * scale, 1.5 * scale), text(fill: blue)[$x' = 0$ \ $(y = 1 - 2x)$])

      // קו y' = 0 (המשוואה y = x - 1) - בצבע אדום
      line((-0.5 * scale, -1.5 * scale), (2.5 * scale, 1.5 * scale), stroke: red + 1.5pt)
      content((2.2 * scale, 0.5 * scale), text(fill: red)[$y' = 0$ \ $(y = x - 1)$])

      // נקודת החיתוך של שיווי המשקל המעורב (2/3, -1/3)
      circle((0.666 * scale, -0.333 * scale), radius: 0.06, fill: black)
      content((0.666 * scale + 0.45, -0.333 * scale - 0.25), $(2/3, -1/3)$)

      // ==========================================
      // סימון התחומים ברביע הראשון (כמו שהשאלה ביקשה)
      // ==========================================

      // אזור 1: המשולש שקרוב לראשית הצירים (מתחת לקו הכחול)
      content((0.22 * scale, 0.22 * scale), text(size: 10pt)[
        $x' > 0$ \ $y' < 0$
      ])

      // אזור 2: החלק העליון והמרכזי (מעל שני הקווים)
      content((1 * scale, 1.2 * scale), text(size: 10pt)[
        $x' < 0$ \ $y' < 0$
      ])

      // אזור 3: מתחת לקו האדום (מימין ל- x=1)
      content((1.8 * scale, 0.3 * scale), text(size: 10pt)[
        $x' < 0$ \ $y' > 0$
      ])
    }))
  ]
]

#subquestion()
נוכיח כי כל הפתרונות שמתחילים ברביע הראשון מתכנסים לנקודת שיווי משקל כלשהי של המערכת.

#proof[
  נבחין שברביע הראשון אין נקודות שיווי משקל עם ערכי $y$ חיובים.\
  לכל $(x,y)$ ברביעי הראשון, אם $x>1/2$ בוודאי שמתקיים $1-2x<0$ ולכן הביטוי $x(1-y-2x) < 0$ קרי $x(t)$ יורדת חזק וככל שהפתרון מתקדם $x(t)$ ייקטן וויכנס לתחום שבו $x<=1/2$.\
  ברגע ש־$x<1/2$ הביטוי $x-1-y$ הוא בהכרח שלילי ממש וחסום מלעיל על־ידי $-1/2-y$ ולכן $y^prime$ תמיד שלילי ברביע הזה כלומר $y(t)$ יילך וידעך לאפס.\
  כאשר $y(t) arrow 0$ המערכת מתכנסת לנקודות שיווי המשקל היחידה שנמצאת על גבול התחום והיא $(1/2, 0)$, כנדרש.
]

#question()
נניח כי $F:Omega arrow RR^n$ שדה גזיר ברציפות כך ש־$0$ נקודת שיווי משקל של המערכת $x^prime = F(x)$.\
נסמן ב־$A=D_0 F$ את הדיפרנציאל של $F$ ב־$0$ ונניח כי כל הערכים העצמיים של $A$ בעלי חלק ממשי שלילי.

#subquestion()
נראה כי הגבול
$ S = integral_0^infinity exp(t A)^T exp(t A) dif t $
קיים ונראה כי $S$ מטריצה חיובית בהחלט ושלכל $x in RR^n$ מתקיים
$ chevron.l S x bar A x chevron.r = - 1/2 norm(x)_2^2 $

#proof[
  מלמה שראינו בהוכחה של הקריטריון הלינארי נובע שקיים $C$ ו־$a>0$ כך ש־$norm(exp(t A)) <= C e^(-t a)$ לכל $t>=0$ ולכן הביטוי המקביל לאינטגרנד
  $ norm(exp(t A)^T exp(t A)) <= C^2 e^(-2t a) $
  הוא כמובן דועך אקספוננציאלית והאינטגרל של $S$ בהכרח מתכנס.\
  לכל $x!=0$ התבנית הריבועית מקיימת
  $
    chevron.l S x, x chevron.r = integral_0^infinity chevron.l exp(t A)^T exp(t A)x, x chevron.l dif t = integral_0^infinity norm(exp((t A)x))^2 dif t
  $
  אבל מטריצת האקספוננט תמיכה הפיכה ו־$norm(exp(t A)x)>0$ ולכן האינטגרל חיובי ממש.\
  נסמן $x(t)=exp(t A) x$ ולכן
  $
    x^prime (t) = A exp(t A) x = exp(t A) A x \
    chevron.l S x, A x chevron.r = integral_0^infinity chevron.l x(t), x^prime chevron.r dif t
  $
  זה בידיוק אינטגרל על החצי של הנגזרת ומהמשפט היסודי
  $ integral_0^infinity 1/2 norm(x(t))^2 dif/(dif t) = 1/2(norm(x(infinity))^2-norm(x(0))^2) $
  אבל $lim_(t arrow infinity) exp(t A)x = 0$ מהערכים העצמיית ולכן נקבל
  $ -1/2 norm(x(0))^2 = -1/2 norm(x)_2^2 $
]

#subquestion()
נראה כי הפונקציה $L(x)=chevron.l S x bar x chevron.r$ כאשר $S$ היא המטריצה מהסעיף הקודם היא פונקציית ליאפונוב חזקה עבור $F$ בסביבה של $0$ ונסיק כי $0$ היא נקודת שיווי משקל יציבה אסימפטוטית של המערכת $x^prime = F(x)$.

#proof[
  מהסעיף הקודם $L(x)>0$ לכל $x!=0$ ו־$L(0)=0$ כלומר ל־$L$ יש מינימום ממש בראשית וזה בידיוק התנאי הראשון של פונקציית ליאפונוב.\
  מהגדרה
  $ F(x) = F(0) + A x + o(norm(x)) = A x + o(norm(x)) $
  נחשב
  $
    chevron.l gradient L(x), F(x) chevron.r = 2 chevron.l S x, F(x) chevron.r = 2 chevron.l S x, A x + o(norm(x)) chevron.l = 2 chevron.l S x, A x chevron.r + 2 chevron.l S x, o(norm(x)) chevron.r
  $
  אבל מהסעיף הקודם $2 chevron.l S x, A x chevron.r = -norm(x)^2$ ו־$o(norm(x))$ דועך מהר יותר לאפס מ־$norm(x)$ ולכן בסביבה מספיק קטנה של $0$ המכפלה השנייה זניחה ביחס ל־$-norm(x)^2$ כלומר היא קטנה מ־$1/2 norm(x)^2$ בערך מוחלט.\
  אז בסביבה של $0$ מתקיים
  $ chevron.l gradient L(x), F(x) chevron.r <= -norm(x)^2 + 1/2 norm(x)^2 = -1/2 norm(x)^2 < 0 $
  כלומר הנגזרת שלילית ממש מחוץ לראשית ולכן $L(x)$ היא פונקציית ליאפונוב חזקה וממשפט ליאפונוב זה אומר ש־$(0,0)$ היא יציבה אסימפטוטית.

]
