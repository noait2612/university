#question()
#subquestion()
נמצא פתרונות כלליים למשוואה
$ x^prime (t) = mat(-5, 1; 4, -2) x(t) $
נצייר דיאגרמת זרימה המתאימה למשוואה האחרונה ונקבע האם ראשית הצירים היא נקודת שווי משקל יציבה או
לא.

#proof[
  נמצא את הערכים העצמיים של מטריצת המקדמים $A$: $ P_A (lambda) = det(lambda I_2 - A) = det mat(lambda +5, -1; -4, lambda+2) = (lambda+5)(lambda+2) - 4 = lambda^2 + 7 lambda + 10 - 4 = lambda^2 + 7 lambda + 6 $
  ולערך הערכים העצמיים של $A$ הם $lambda_1 = -1, lambda_2 = -6$.\
  נמצא וקטורים עצמיים
  + עבור $lambda_1 = -1$ נפתור את המערכת $(A+I) v_1 = 0$ כלומר
    $ (A+I) v_1 = 0 <==> (mat(-5, 1; 4, -2)+ mat(1, 0; 0, 1))v_1 = 0 <==> mat(-4, 1; 4, -1)v_1 = 0 <==> y = 4x $
    ולכן הוקטור העצמי המתאים הוא $v_1 = vec(1, 4)$
  + עבור $lambda_2 = -6$ נפתור את המערכת $(A+6I) v_2 = 0$ כלומר
    $ (A + 6I)v_2 = 0 <==> mat(1, 1; 4, 4) v_2 = 0 <==> y=-x $
    ולכן הוקטור העצמי המתאים הוא $v_2 = vec(1, -1)$
  הפיתרון הכללי הוא
  $ x(t)=c_1 e^(-t) vec(1, 4) + c_2 e^(-6t) vec(1, -1) $
  יש לנו שני ערכים עצמיים ממשיים שליליים ולכן הדיאגרמה המתאימה לכך היא
  #figure(
    image("../../../src/images/differential equations ex06 question 1a.png", width: 20%, height: 20%, fit: "contain"),
  )
  נבחין שכאשר $t arrow infinity$ הן $e^(-6t)$ והן $e^(-t)$ מתכנסים לאפס ולכן כל פיתרון של המערכת שואף לראשית הצירים ולכן זו נקודת שיווי משקל יציבה (ואף יציבה אסימפטוטית).
]

#subquestion()
נמיר את המשוואה $x^prime.double +x^prime-2x=0$ במערכת משוואות מסדר ראשון, נמצא פתרון כללי למשוואות ונצייר דיאגרמת זרימה מתאימה למערכת.

#solution[
  נגדיר $x_1 = x, x_2 = x^prime$ ולכן נקבל משוואה מסדר ראשון $x_1^prime = x_2$ וכן
  $ x_2^prime = x^prime.double = 2x-x^prime = 2x_1-x_2 $
  ובכתיב מטריציוני
  $ vec(x_1^prime, x_2^prime) = mat(0, 1; 2, -1) vec(x_1, x_2) $
  נמצא ערכים עצמיים, הפולינום האופייני הוא
  $ P_A (lambda)=lambda(lambda+1)-2=lambda^2+lambda-2 = (lambda-1)(lambda+2) $
  ולכן הערכים העצמיים של המטריצה $A$ הם $lambda_1 = 1$ ו־$lambda_2 = -2$, שוב נמצא וקטורים עצמיים
  + עבור $lambda_1 = 1$ נפתור את המערכת $(A-I)v_1 = 0$ כלומר
    $ mat(-1, 1; 2, -2) vec(x, y) = 0 <==> y=x $
    לכן וקטור עצמי מתאים הוא $v_1 = vec(1, 1)$
  + עבור $lambda_2 = -2$ נפתור את המערכת $(A+2I)v_2 = 0$ כלומר
    $ mat(2, 1; 2, 1) vec(x, y) = 0 <==> y = -2x $
    לכן וקטור עצמי מתאים הוא $v_2 = vec(1, -1)$
  הפיתרון הכללי הוא
  $ x(t) = c_1 e^t vec(1, 1) + c_2 e^(-2t) vec(1, -2) $
  יש לנו ערך עצמי חיובי וערך עצמי שלילי ולכן ראשית הצירים היא נקודת אוכף שכן
  לאורך הישר $y = -2x$ (הכיוון של $v_2$), הפתרונות דועכים ושואפים אל הראשית בגלל המעריך השלילי $e^(-2t)$.  מצד שני, לאורך הישר $y = x$ (הכיוון של $v_1$), הפתרונות מתרחקים מהראשית בגלל המעריך החיובי $e^t$.\
  כל שאר המסלולים במרחב זורמים מתוך הישר של $v_2$ ומתעקלים החוצה בכיוון האסימפטוטי של הישר $v_1$.\
  כלומר, זו נקודת שיווי משקל לא יציבה.
  #figure(
    image("../../../src/images/differential equations ex06 question 1b.png", width: 20%, height: 20%, fit: "contain"),
  )
]

#question()
תהיי $F: Omega arrow RR^n$ ליפשיץ מקומית ונתבונן בבעיית תנאי ההתחלה
$ cases(x^prime = F(x), x(0)=x_0) $
נניח כי הקורדינאטות של $F$ כולן אי־שליליות (ולכן הקורדינאטות של פתרון של הבעיה יהיו מונוטוניות עולות).\
תהיי $U subset Omega$ פתוחה וחסומה כך שמתקיים $closure(U) subset Omega$ ונסמן את הפיתרון המקסימלי לבעיה לעיל ב־$x$ ונניח כי $x_0 in U$.\
נוכיח כי לפחות אחת מהאפשרויות הבאות מתקיימת
+ $x$ מגיע לשפה של $U$ בזמן סופי
+ הגבול $lim_(t arrow infinity) x(t)$ קיים ונמצא ב־$closure(U)$ והנקודה $lim_(t arrow infinity) x(t)$ היא נקודת שיווי משקל של $F$

#proof[
  נניח בשלילהש־$x(t)$ מוגדר לכל $t >= 0$ ואינו מגיע לשפה בזמן סופי, כלומר $x(t) in U$ לכל $t >= 0$.\
  מכיוון ש־$U$ היא קבוצה חסומה (ונתון $closure(U) subset Omega$), הסדרה הרציפה $x(t)$ מונוטונית עולה (בכל קואורדינטה) וחסומה מלעיל.\
  ממשפט ההתכנסות המונוטונית נובע שהגבול $L = lim_(t arrow infinity) x(t)$ קיים ומכיוון ש־$x(t) in U$ נובע כי $L in closure(U) subset Omega$.\
  נותר להראות ש־$L$ היא נקודת שווי משקל של $F$, כלומר ש־$F(L) = 0$.\
  מכיוון ש־$F$ רציפה (ליפשיץ מקומית), מתקיים:
  $ lim_(t arrow infinity) x'(t) = lim_(t arrow infinity) F(x(t)) = F(L) $
  נניח בשלילה ש־$F(L) != 0$ אז קיימת קואורדינטה $i$ כךש־$F_i (L) > 0$.\
  מרציפות $F$ קיים $epsilon > 0$ ו־$T>0$ כך שלכל $t>T$ מתקיים $x_i^prime (t) > epsilon$ ומאינטגרציה נקבל
  $ x_i (t) - x_i (T) = integral_T^t x_i^' (s) dif s > integral_T^t epsilon dif s = epsilon(t-T) $
  כאשר $t arrow infinity$, הפונקציה $x_i (t) arrow infinity$, וזה בסתירה לכך ש־$x(t)$ חסומה (שכן $x(t) in U$) כלומר בהכרח מתקיים $F(L) = 0$, ו־$L$ היא נקודת שווי משקל.
]

#question()
#subquestion()
נתבונן במשוואה $a(t)x^prime.double (t) + b(t) x^prime (t) + c(t) x(t) = 0$ ונניח ש־$y(t)$ היא פונקציה שפותרת את המשוואה.\
נראה כי פונקציה מהצורה $z(t) = v(t) y(t)$ פותרת את המשוואה אם ורק אם $v^prime (t)$ פותרת משוואה מסדר ראשון.

#proof[
  נחשב את הנגזרות של $z(t)$
  $
    z^prime (t) = v^prime (t)y(t) + v(t)y^prime (t) \
    z^prime.double (t) = v^prime.double (t)y(t) + 2v^prime (t)y^prime (t) + v(t)y^prime.double (t)
  $
  נציב במשוואה הנתונה ונקבל
  $
    a(t)[v^prime.double (t)y(t) + 2v^prime (t)y^prime (t) + v(t)y^prime.double (t)] + b(t)[v^prime (t)y(t) + v(t)y^prime (t)] + c(t)[v(t)y(t)] = 0
  $
  סידור מחדש יניב לנו
  $
    v(t) [a(t)y^prime.double (t) + b(t)y^prime (t) + c(t)y(t)] + v^prime (t) [2a(t)y^prime (t) + b(t)y(t)] + v^prime.double (t) [a(t)y(t)] = 0
  $
  נתון כי $y(t)$ היא פונקציה שפותרת את המשוואה המקורית, ולכן הביטוי בסוגריים הראשונים מתאפס בהכרח ($a(t)y^prime.double + b(t)y^prime + c(t)y = 0$) ונקבל
  $
    [a(t)y(t)] v^prime.double (t) + [2a(t)y^prime (t) + b(t)y(t)] v^prime (t) = 0
  $
  כעת, נגדיר משתנה חדש $u(t) colon.eq v^prime (t)$ ולכן $u^prime (t) = v^prime.double (t)$.\
  נציב ונקבל
  $ [a(t)y(t)] u^prime (t) + [2a(t)y^prime (t) + b(t)y(t)] u(t) = 0 $
  זוהי משוואה דיפרנציאלית לינארית והומוגנית מסדר ראשון עבור $u(t)$ (שהוא $v^prime (t)$).\
  כלומר קיבלנו ש־$z(t)$ פותרת את המשוואה המקורית אם ורק אם $v^prime (t)$ פותרת את המשוואה מסדר ראשון שקיבלנו.
]

#subquestion()
נשתמש בשיטת הורדת הסדר עבור המשוואה $x^prime.double c^2 x$ וידוע כי $y(t) = e^(c t)$ פתרון למשוואה.
נשתמש בשיטת הורדת הסדר כדי למצוא פתרון נוסף.

#proof[
  המשוואה הנתונה היא $x^prime.double (t) - c^2 x(t) = 0$, כלומר במקרה זה המקדמים הם
  $ a(t) = 1, quad b(t) = 0, quad c(t) = -c^2 $
  מהסעיף הקודם הפונקציה $z(t)=v(t)y(t)$ פותרת את המשוואה אם ורק אם $u(t)=v^prime (t)$ פותרת את המשוואה מסדר ראשון
  $ [a(t)y(t)] u^prime (t) + [2a(t)y^prime (t) + b(t)y(t)] u(t) = 0 $  נחשב את הנגזרת של הפתרון הנתון $y^prime (t) = c e^(c t)$.\
  נציב את הרכיבים הללו במשוואה עבור $u(t)$:
  $
    [1 dot.op e^(c t)] u^prime (t) + [2 dot.op 1 dot.op c e^(c t) + 0 dot.op e^(c t)] u(t) = 0 <==> e^(c t) u^prime (t) + 2c e^(c t) u(t) = 0
  $
  נחלק ב־$e^(c t)$ (שהוא תמיד שונה מאפס) ונקבל משוואה לינארית פשוטה הנתנת להפרדת משתנים $ u^prime (t) + 2c u(t) = 0 <==> u^prime (t) = -2c u(t) \
  frac(d u, d t) = -2c u \
  sum frac(1, u) d u = sum -2c d t \
  ln abs(u) = -2c t + C_1u(t) = C_2 e^(-2c t) $
  נבחר את הקבוע $C_2=1$ ומכוון ש־$u(t)=v^prime (t)$ מאינטגרציה נקבל
  $ v(t) = sum u(t) d t = sum e^(-2c t) d t = -frac(1, 2c) e^(-2c t) $
  כעת, נחזור לפונקציה $z(t)$ $ z(t) = v(t) y(t) = (-frac(1, 2c) e^(-2c t)) dot.op e^(c t) = -frac(1, 2c) e^(-c t) $
  מכיוון שהמשוואה המקורית היא לינארית והומוגנית, כל כפילת פתרון בקבוע קבוע היא גם פתרון.\
  נוכל להשמיט את המקדם הבלתי תלוי $-frac(1, 2c)$ ולקבל שהפתרון הנוסף הבלתי תלוי ליניארית הוא $z(t) = e^(-c t)$.
]

#subquestion()
משוואת אויילר היא משוואה לינארית מסדר שני מהצורה
$ a t^2 x^prime.double (t) + b t x^prime (t) + c x(t) =0 $
כדי לפתור את משוואת אוילר מנסים למצוא $r$ כך שהפונקציה $t^r$ פתרון למשוואה.\

#sub_subquestion()
נעזר בשיטה לעיל כדי למצוא פיתרון כללי למשוואה $t^2 x^prime.double (t) + 7t x^prime (t) + 5x(t) = 0$.

#solution[
  נחשב את הנגזרות המתאימות
  $ x^prime (t) = r t^(r-1) x^prime.double (t) = r(r-1) t^(r-2) $
  נציב את הנגזרות הללו לתוך המשוואה הנתונה $t^2 x^prime.double (t) + 7t x^prime (t) + 5x(t) = 0$
  $
    t^2 [r(r-1) t^(r-2)] + 7t [r t^(r-1)] + 5t^r = 0 <==> r(r-1) t^r + 7r t^r + 5t^r = 0 <==> t^r [r(r-1) + 7r + 5] = 0
  $
  מכיוון שפתרון זה נדרש להתקיים באופן כללי (עבור $t != 0$), הביטוי בסוגריים המרובעים חייב להתאפס.\
  נקבל את המשוואה האופיינית של משוואת אוילר
  $ r^2 - r + 7r + 5 = 0r^2 + 6r + 5 = 0 <==> (r+1)(r+5) = 0 $
  ולכן השורשים הם $r_1 = -1$ ו־$r_2 = -5$.\
  קיבלנו שני פתרונות יסודיים בלתי תלויים ליניארית: $x_1 (t) = t^(-1)$ ו־$x_2 (t) = t^(-5)$. \
  הפתרון הכללי של המשוואה הוא צירוף ליניארי שלהם $ x(t) = c_1 t^(-1) + c_2 t^(-5) = frac(c_1, t) + frac(c_2, t^5) $
]

#sub_subquestion()
נעזר בשיטה לעיל כדי למצוא פיתרון כללי למשוואה $t^2 x^prime.double (t) -3t x^prime (t) + 4x(t) = 0$.

#solution[
  נחפש תחילה פתרון מהצורה $x(t) = t^r$.\
  נציב את הנגזרות $x^prime (t) = r t^(r-1)$ ו־$x^prime.double (t) = r(r-1) t^(r-2)$ במשוואה הנתונה ונקבל
  $ t^2 [r(r-1) t^(r-2)] - 3t [r t^(r-1)] + 4t^r = 0 t^r [r(r-1) - 3r + 4] = 0 $
  עבור $t != 0$, נקבל את המשוואה $ r^2 - r - 3r + 4 = 0r^2 - 4r + 4 = 0(r-2)^2 = 0 $
  קיבלנו שורש כפול $r = 2$.\
  אז פתרון יסודי ראשון הוא $y(t) = t^2$ וכדי למצוא פתרון שני נשתמש בשיטת הורדת הסדר שפיתחנו בשאלה עבור המקדמים $a(t) = t^2$ ו־$b(t) = -3t$.\
  הפונקציה $z(t) = v(t)y(t)$ היא פתרון אם ורק אם $u(t) = v^prime (t)$ פותרת את המשוואה
  $ [a(t)y(t)] u^prime (t) + [2a(t)y^prime (t) + b(t)y(t)] u(t) = 0 $  נחשב את הנגזרת של הפתרון הראשון $y^prime (t) = 2t$, נציב ונקבל
  $
    [t^2 dot.op t^2] u^prime (t) + [2 dot.op t^2 dot.op (2t) + (-3t) dot.op t^2] u(t) = 0 t^4 u^prime (t) + [4t^3 - 3t^3] u(t) = 0t^4 u^prime (t) + t^3 u(t) = 0
  $
  נחלק ב־$t^3$ (עבור $t != 0$) ונקבל משוואה הניתנת להפרדת משתנים $ t u^prime (t) + u(t) = 0t frac(d u, d t) = -u frac(1, u) d u = -frac(1, t) d t ln abs(u) = -ln abs(t) + C u(t) = frac(1, t) $
  מכיוון ש־$u(t) = v^prime (t)$, נמצא את $v(t)$ על ידי אינטגרציה:
  $ v(t) = sum u(t) d t = sum frac(1, t) d t = ln t $
  כלומר $z(t)=v(t)y(t)=t^2 ln t$.\
  אז יש לנו שני פתרונות בלתי־תלויים לינארית $t^2 ln t, t^2$ ולכן הפתרון הכללי למשוואה הוא $x(t) = c_1 t^2 + c_2 t^2 ln t$.
]

#question()
נתבונן במערכת
$ vec(x^prime, y^prime) = vec(x+x y - sqrt(x^2+y^2)(x+y), y-x^2 + sqrt(x^2+y^2)(x-y)) $
ונשים לב ש־$(1,0)$ נקודת שיווי משקל של המערכת.

#subquestion()
נניח כי $(x(t), y(t))$ פתרון ונסמן את הקורדינאטות הפולאריות $(r(t), phi(t))$ של הפתרון, כלומר הפונקציות $r,phi$ מוגדרות על־ידי
$
  x(t) = r(t) cos(phi(t)) \
  y(t) = r(t) sin(phi(t))
$
נראה כי
$
  r^prime (t) = r(t)(1-r(t)) \
  phi^prime (t) = r(t)(1-cos(phi(t)))
$

#proof[
  נסמן $R = sqrt(x^2 + y^2) = r(t)$ ומתקיים $r^2 = x^2 + y^2$, נגזור לפי $t$ ונקבל
  $ 2r r^prime = 2x x^prime + 2y y^prime arrow.r r r^prime = x x^prime + y y^prime $
  נציב את הביטויים של $x^prime$ ו־$y^prime$ מתוך המערכת הנתונה:
  $
    x x^prime + y y^prime & = x [x + x y - r(x+y)] + y [y - x^2 + r(x-y)] \
                          & =
                            x^2 + cancel(x^2 y) - r x^2 - cancel(r x y) + y^2 - cancel(x^2 y) + cancel(r x y) - r y^2 \
                          & = x x^prime + y y^prime \
                          & = (x^2 + y^2) - r(x^2 + y^2) \
                          & = r r^prime \
                          & = r^2 - r(r^2) = r^2 (1 - r)
  $
  אם $r!=0$ ניתן לחלק ולקבל את המשוואה הראשונה $r^prime (t) = r(t)(1 - r(t))$.\
  מתקיים $tan(phi) = x/y$ ולכן אם נגזור לפי $t$ נקבל
  $
    frac(1, cos^2(phi)) phi^prime = frac(y^prime x - x^prime y, x^2) <==>_(cos^2(phi) = frac(x^2, r^2)) phi^prime = frac(x^2, r^2) dot.op frac(x y^prime - y x^prime, x^2) = frac(x y^prime - y x^prime, r^2)
  $
  אז
  $
    x y^prime - y x^prime & = x [y - x^2 + r(x-y)] - y [x + x y - r(x+y)] \
                          & = cancel(x y) - x^3 + r x^2 - cancel(r x y) - cancel(x y) - x y^2 + cancel(r x y) + r y^2 \
                          & = x y^prime - y x^prime \
                          & = -x^3 - x y^2 + r x^2 + r y^2 \
                          & = -x(x^2 + y^2) + r(x^2 + y^2)
  $
  נציב שוב $x^2 + y^2 = r^2$
  $ x y^prime - y x^prime = -x r^2 + r(r^2) = r^2 (r - x) $
  נציב את המונה חזרה במשוואה של $phi^prime$
  $ phi^prime = frac(r^2 (r - x), r^2) = r - x $
  נשתמש בהגדרת הקואורדינטות הפולאריות $x = r cos(phi)$
  $ phi^prime = r - r cos(phi) = r(1 - cos(phi)) $
  וקיבלנו את הנדרש.
]

