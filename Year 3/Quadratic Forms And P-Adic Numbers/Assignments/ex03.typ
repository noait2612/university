#question()
יהי $2<p$ ראשוני, $(V,q)$ מרחב ריבועי לא מנוון מעל $FF_p$, $dim V =2$ ו־$cal(B)$ בסיס של $V$.\
נוכיח כי $q(V without {0}) = FF_p^times$ אם ורק אם $-det[g_q]_cal(B) in.not (FF_p^times)^2$.

#proof[\
  $<==$ נניח בשלילה ש־$-det [g_q]_cal(B) in (FF_p^times)^2$ ולכן מטענה שראינו בהרצאה נובע ש־$(V,q)$ הוא איזוטרפי ולכן ממסקנה שראינו בהרצאה נקבל ש־$q(V without {0})=FF_p$ כלומר התמונה של התבנית זה גם וקטור האפס בסתירה להנחה ש־$q(V without {0}) = FF_p^times$.\
  $==>$  מכך ש־$dim V = 2$, מטענה שראינו בהרצאה נקבל ש־$FF_p^times subset.eq q(V without {0})$.\
  לכן, אם בשלילה $0 in q(V without {0})$ אז נקבל שהמרחב הוא איזוטרפי אבל מטענה שראינו יינבע $-det [g_q]_cal(B) in (FF_p^times)^2$, בסתירה.
]

#question()
יהי $2<p$ ראשוני, $(V,q)$ מרחב ריבועי לא מנוון מעל $FF_p$, $dim V=3$ ו־$r in FF_p^times without (FF_p^times)^2$.\
נוכיח כי קיים $a in {1,r}$ ובסיס $cal(B)$ של $V$ כך שמתקיים
$ [g_q]_cal(B) = mat(0, 1/2, 0; 1/2, 0, 0; 0, 0, a) $

#proof[
  מטענה שראינו בהרצאה כל מרחב ריבועי לא מנוון מעל $FF_p$ ממימד $dim V >=3$ הוא מרחב איזוטרופי ולכן קיים תת־מרחב $U subset.eq V$ ממימד $2$ שהיא איזומורפי למישור ההיפרבולי $(FF_p^2, h)$ ויש לו בסיס שבו מטריצת התבנית היא $mat(0, 1/2; 1/2, 0)$ כאשר הבסיס הוא $cal(B)_1 = (u_1, u_2)$.\
  $(U, q|_U)$ לא מנוון ולכן $V = U plus.o^perp U^perp$ אבל לפי משפט המימדים מההרצאה/תרגיל הקודם $dim U^perp = 1$ ומרחב לא מנוון ממימד $1$ מיוצג על־ידי סקלר יחיד שהוא בקבוצת הנציגים של השדה ולכן במקרה של ${1,r}$.\
  נשאר רק לבנות את הבסיס המבוקש: יהי $w != 0_V$ וקטור בסיס ל־$U^perp$ ומאחר ש־$(U^perp, q|_(U^perp))$ לא מנוון מתקיים $q(w)=g_q (w,w) = a_0 !=0$.\
  מכך ש־$p!=2$ אז עבור השדה $FF_p$ קבוצת הנציגים של השדה היא $R={1,r}$ כאשר $r in FF_p^times without (FF_p^times)^2$ ולפי משפט שראינו בהרצאה ניתן למתוח את וקטור הבסיס כך שערך התבנית עליו יהיה שייך לקבוצת הנציגים ולכן קיים $u_3 in U^perp$ עבורו $q(u_3) = g_q (u_3, u_3) = a$ עבור $a in {1,r}$.\
  נגדיר $cal(B) = (u_1, u_2, u_3)$ ומתקיים $g_q (u_2, u_3) = g_q (u_1, u_3) = 0$ ולכן מטריצת גראם תהיה
  $ [g_q]_cal(B) = mat(0, 1/2, 0; 1/2, 0, 0; 0, 0, a) $
  כאשר $a in {1, r}$, כנדרש.
]

#question()
תבנית ריבועית $q:FF_7^3 arrow FF_7$ מוגדרת על־ידי $ q vec(x_1, x_2, x_3) = x_1^2 + x_2^2 + x_3^2 $
נמצא $a in {1,-1}$ ובסיס $cal(B)$ של $FF_7^3$ כך שמתקיים
$ [g_q]_cal(B) = mat(0, 1/2, 0; 1/2, 0, 0; 0, 0, a) $

#solution[
  אנחנו מחפשים $u_1 = vec(x_1, x_2, x_3) != 0$ כך ש־$q(u_1) = 0$ כלומר
  $ x_1^2+x_2^2+x_3^2 eq.triple_(mod 7) 0 $
  אנחנו יודעים שהריבועים ב־$FF_7$ הם בידיוק $0^2=0, 1^2 = 1, 2^2 = 4, 3^2 = 9 = 2$ (השאר חוזרים על עצמם כי $4^2=16 eq.triple_(mod 7) 2, 5^2 = 25 eq.triple_(mod 7) 4, 6^2 = 36 eq.triple_(mod 7) 1$).\
  ובזכות קאקורו אנחנו יודעים שהקומבינציה היחידה היא $1+4+2 = 7 eq.triple_(mod 7) 0$.\
  אז אם נבחר $x_1 = 1, x_2 = 2, x_3 = 3$ נקבל ש־$q(u_1) = 0$ ולכן $u_1 = vec(1, 2, 3)$ זה הוקטור הראשון שלנו.\
  נשים לב כמובן
  $ g_q (u,w) = u_1 w_1 + u_2 w_2 + u_3 w_3 $
  ושהמטריצה המייצגת של התבנית בבסיס הסטנדרטי היא פשוט $I_3$.\
  אנחנו צריכים וקטור $w$ כך ש־$g_q (u_1, w) != 0$ כמו לדוגמה $w = vec(1, 0, 0)$ כי אז
  $ g_q (u_1, w) = 1 dot.op 1 = 1 = b $
  מהאלגוריתם בהרצאה נגדיר $w^prime$ כך ש־$g_q (u_1, w^prime) = 1/2$ כי $1/2 eq.triple_(mod 7) 4$ וכן $2 dot.op 4 = 8 eq.triple_(mod 7) = 1$ ואז
  $ w^prime = 1/(2b) w = 4 dot.op vec(1, 0, 0) = vec(4, 0, 0) $
  מתקיים
  $ q(w^prime) = r^2 + 0^2 + 0^2 = 16 eq.triple_(mod 7) 2 $
  ועכשיו
  $ u_2 = w^prime - q(w^prime)u_1 = vec(4, 0, 0) - 2 vec(1, 2, 3) = vec(2, 3, 1) $
  מתקיים $q(u_1) eq.triple_(mod 7) 0$ וגם $q(u_2) eq.triple_(mod 7) 0$ וכן
  $ g_q (u_1, u_2) = 1 dot.op 2 + 2 dot.op 3 + 3 dot.op 1 = 2 + 6 + 3 = 11 eq.triple_(mod 7) 4 eq.triple_(mod 7) 1/2 $
  כלומר מצאנו בלוק היפרבולי ראשון $display(mat(0, 1/2; 1/2, 0))$.\
  כעת נמצא מציאת אורתוגונלי $U^perp$ והוקטור השלישי חייב להיות אורתוגונלי ל־$u_2, u_1$ כלומר לקיים את מערכת המשוואות
  $
    cases(g_q (u_1 comma u_3) = 0 ==> x_1 + 2x_2 + 3x_3 eq.triple_(mod 7) 0, g_q (u_2 comma u_3) = 0 ==> 2x_1 + 3x_2 + x_3 eq.triple_(mod 7) 0)
  $
  נחסר פעמיים את המשוואה הראשונה מהשנייה ונקבל
  $
    2x_1 + 3x_2 + x_3 - 2(x_1 + 2x_2 + 3x_3) eq.triple_(mod 7) 0 ==> -x_2 - 5x_3 eq.triple_(mod 7) 0 ==> x_2 eq.triple_(mod 7) 2x_2
  $
  #pagebreak()
  ולכן
  $ x_1 + 2(2x_3) + 3x_3 eq.triple_(mod 7) 0 ==> x_1 + 7x_3 eq.triple_(mod 7) 0 ==> x_q eq.triple_(mod 7) 0 $
  נסיים לפתור את מערכת המשוואות ונקבל $u_3 = vec(0, 2, 1)$, צריך לוודא אם צריך לנרמל
  $ q(u_3) = 0^2+2^2+1^2 = 4+1=5 eq.triple_(mod 7) -2 $
  עלינו לבחון האם ניתן למתוח את $u_3$ על־ידי סקלר $c$ כך ש־$q(c u_3) = c^2 5 in {-1, 1}$
  + אם $c^2 dot.op 5 eq.triple_(mod 7) 1$ אז אם נכפול ב־$3$ (שהוא ההופכי של $5$) נקבל $c^2 eq.triple_(mod 7) 3$ וזה לא ייתכן כי זה לא ריבוע בשדה
  + אם $c^2 dot.op 5 eq.triple_(mod 7) -1 eq.triple_(mod 7) 6$ נכפיל ב־$3$ ונקבל $c^2 eq.triple_(mod 7) 18 eq.triple_(mod 7) 4$ ו־$4$ הוא כן ריבוע עבור $c=2$ או $c=5$
  אז אם נבחר $c=2$ נקבל $u_3 = vec(0, 4, 2)$ ו־$q(u_3) = -1$ ולכן $a=-1$ והבסיס המבוקש הוא $cal(B)={vec(1, 2, 3), vec(2, 3, 1), vec(0, 4, 2)}$.
]

#question()
יהי $2<p$ ראשוני, $(V,q)$ מרחב ריבועי לא מנוון מעל $FF_p$ ו־$dim V = 8$. נוכיח כי קיים תת־מרחב $U$ של $V$ כך ש־$dim U = 3$ וגם $q|_U =0$.

#proof[
  מטענת הפירוק שראינו בהרצאה קיים $m in NN union {0}$ ותתי־מרחבים $U_1, dots.h, U_m , W$ של $V$ כך שמתקיים
  $ V = U_1 plus.o^perp dots.h.c plus.o^perp U_m plus.o^perp W $
  כאשר לכל $1<=i<=m$ מתקיים $(U_i, q|_U_i)$ הוא מישור היפרבולי ו־$(W, q|_W)$ הוא מרחב אנאיזוטרופי.\
  מטענה שראינו בהרצאה כל מרחב ריבועי לא מנוון מעל $FF_p$ שמימדו $>=3$ הוא מרחב איזוטרופי ובהגדרת הפירוק $(W, q|_W)$ הוא אנאיזוטרופי נובע ש־$dim W <=2$.\
  מתקיים
  $ 8 = dim V = sum_(i=1)^m dim U_i + dim W = 2m + dim W $
  ולכן $ 2m=-8 dim W >= 8-2 = 6 <==> m>=3 $
  נתבונן ב־$U_1, U_2, U_3$ ולפי הגדרת המישור ההיפרבולי לכל $1<=i<=3$ מתקיים ש־$q|_U_i$ היא תבנית איזוטרופית ולכן קיים $0!=u_i in U_i$ כך ש־$q(u_i)=0$ אז נגדיר \
  $U = Span(u_1, u_2, u_3)$ והם בלתי־תלויים לינארית מהסכום הישר ולכן $dim U = 3$.\
  נשאר רק לבדוק שהם מאפסים את התבנית: יהי $v in U$ ולכן $v=c_1 u_1 + c_2 u_2 + c_3 u_3$ עבור $c_1, c_2, c_3 in FF_p$.\
  מהיות $U_1, U_2, U_3$ אורתוגונליים זה לזה ביחס ל־$g_q$ מתקיים $g_q (u_i, u_j) = 0$ לכל $i!=j$ ולכן
  $
    q(v) = g_q (v,v) = g_q (sum_(i=1)^3 c_i u_i, sum_(i=1)^3 c_i u_i ) = sum_(i=1)^3 c_i^2 g_q (u_i, u_i) = sum_(i=1)^3 c_i^2 q(u_i) =_(q(u_i) = 0) 0
  $
  ולכן לכל $v in U$ מתקיים $q|_U_i$ ולכן $U$ הוא תת־מרחב ממימד $3$ המקיים את הנדרש.
]

#question()
יהיו $(V_1, q_1), (V_2, q_2)$ מרחב ריבועיים. נגדיר פונקציה $q : V_1 times V_2 arrow FF$ על־ידי $q(v_1, v_2) = q_1 (v_1) + q_2 (v_2)$. נוכיח כי $q$ היא תבנית ריבועית.

#proof[
  יהי $(v_1, v_2) in V_1 times V_2$ ויהי $alpha in FF$ מכך ש־$q_1, q_2$ תבניות ריבועיות נקבל
  $
    q(alpha(v_1, v_2)) = q(alpha v_1, alpha v_2) = q_1 (alpha v_1) + q_2 (alpha v_2) = alpha^2 q_1 (v_1) + alpha^2 q_2 (v_2) = alpha^2(q_1(v_1) + q_2 (v_2)) = alpha^2 q(v_1, v_2)
  $
  עלינו להראות בלינאריות: נסמן $g_(q_1), g_(q_2)$ את התבניות הבילנאריות הסימטריות של $q_1, q_2$ בהתאמה.\
  נגדיר $g: (V_1 times V_2) times (V_1 times V_2) arrow FF$ על־ידי
  $ g((v_1, v_2), (w_1, w_2)) = g_(q_1)(v_1, w_1)+g_q_2 (v_2, w_2) $
  וסכום של תבניות בילנאריות סימטריות היא תבנית בילנארית סימטרית.\
  יתר על־כן, לכל $u=(v_1, v_2) in V_1 times V_2$ מתקיים $q(u)=g(u,u)$ ואכן מהיות $g_q_1, g_q_2$ תבניות של $q_1, q_2$ בהתאמה נקבל
  $
    g(u,u) = g((v_1, v_2), (v_1, v_2)) = g_q_1 (v_1, v_1) + g_q_2 (v_2, v_2) = q_1 (v_1) + q_2 (v_2) = q(v_1, v_2) = q(u)
  $
  אז $q$ אכן תבנית ריבועית.
]

#question()
יהיו $(V_1, q_1), (V_2, q_2)$ מרחבים ריבועיים ויהי $(V_1, q_1) times (V_2, q_2)$ מרחב ריבועי עם $q(v_1, v_2) = q_1 (v_1) + q_2 (v_2)$.\
נגדיר $"in"_1 : (V_1, q_1) arrow (V_1, q_1) times (V_2, q_2), "in"_2 : (V_2, q_2) arrow (V_1, q_1) times (V_2, q_2)$ על־ידי
$
  "in"_1 (v) = (v,0) \
  "in"_2 (v) = (0, v)
$
נוכיח כי $"in"_1, "in"_2$ הן איזומטריות וכי $V_1 times V_2 = "in"_1 (V_1) plus.o^perp "in"_2 (V_2)$.

#proof[
  אמרנו ש־$f : V arrow V^prime$ פונקציה היא איזומטריה מעל $(V,q), (V^prime, q^prime)$ מרחבים ריבועיים אם לכל $v in V$ מתקיים $q(v)=q^prime (f(v))$.\
  עבור $v in V_1$ מתקיים
  $ q("in"_1 (v)) = q (v, 0) = q_1 (v) + q_2 (0) = q_1 (v) + 0 = q_1 (v) $
  כי תבנית ריבועית תמיד מעבירה את וקטור האפס לאפס ולכן $"in"_1$ איזומטריה ובאופן דומה נקבל שגם $"in"_2$ היא איזומטרייה.\
  בשביל החלק השני, נסמן
  $ U_1 colon.eq = "in"_1 (V_1) = {(v, 0) bar v in V_1} wide U_2 colon.eq = "in"_2 (V_2) = {(0, v) bar v in V_2} $
  יהי $(v_1, v_2) in V_1 times V_2$, נשים לב
  $ (v_1, v_2) = (v_1, 0) + (0, v_2) = "in"_1 (v_1) + "in"_2 (v_2) in U_1 + U_2 $
  ולכן $V_1 times V_2 = U_1 + U_2$ וסכום המרחבים הוא כל המרחב.\
  יהי $(x,y) in U_1 inter U_2$ וברור כי $(x,y) = (0,0)$ מהגדרת החיתוך ולכן מתקיים $V_1 times V_2 = U_1 plus.o U_2$.\
  נשאר להראות אורתוגונליות ביחס ל־$g_q$: מהשאלה הקודמת
  $ g_q ((v_1, v_2), (w_1, w_2)) = g_(q_1)(v_1, w_1) + g_(q_2)(v_2, w_2) $
  יהיו $u in U_1, w in U_2$ ולכן קיימים $v_1 in V_1, v_2 in V_2$ כך ש־$u=(v_1, 0), w = (0, w_2)$ ומתקיים
  $ g_q (u, w) = g_q ((v_1, 0), (0, w_2)) = g_(q_1)(v_1, 0) + g_(q_2)(0, w_2) = 0+0 = 0 $
  כי $g_q_1, g_q_2$ תבניות בילנאריות ולכן $U_1 perp U_2$.
]

